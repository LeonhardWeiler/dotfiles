#!/bin/sh
# rofi_workspace_manager — waehlt eine Workspace-Konfiguration und startet sie.
# Neue Konfigurationen einfach als weitere Zeile in der Liste + im case ergaenzen.

m() { rofi -dmenu -i -p "Workspace" "$@" ;}

SCRIPTS="$HOME/.local/bin"

choice="$(printf '%s\n' \
  "slf-workspace" \
  | m -l 1)"

case "$choice" in
  slf-workspace) exec "$SCRIPTS/workspace_slf" ;;
  "") exit 0 ;;
  *) rofi -e "Unbekannte Auswahl: $choice"; exit 1 ;;
esac

set -eu

WBG_VERSION="1.3.0"
SRC_DIR="${WBG_SRC_DIR:-$HOME/.local/src/wbg}"
REPO_DEPS="pixman libjpeg-turbo wayland wayland-protocols meson ninja"

if command -v pacman >/dev/null 2>&1; then
	sudo pacman -S --needed --noconfirm $REPO_DEPS

	if ! pkg-config --exists tllist 2>/dev/null; then
		echo "build-wbg: installing tllist (AUR) via yay ..."
		yay -S --needed --noconfirm tllist
	fi
fi

if [ -d "$SRC_DIR/.git" ]; then
	echo "build-wbg: resetting $SRC_DIR to a pristine $WBG_VERSION ..."
	git -C "$SRC_DIR" fetch --tags --depth 1 origin "$WBG_VERSION"
	git -C "$SRC_DIR" checkout -q "$WBG_VERSION"
	git -C "$SRC_DIR" reset -q --hard "$WBG_VERSION"
else
	echo "build-wbg: cloning wbg $WBG_VERSION into $SRC_DIR ..."
	mkdir -p "$(dirname "$SRC_DIR")"
	git clone --depth 1 --branch "$WBG_VERSION" https://codeberg.org/dnkl/wbg.git "$SRC_DIR"
fi

rm -rf "$SRC_DIR/build"
meson setup --buildtype=release \
	-Djpeg=enabled -Dpng=disabled -Dwebp=disabled -Djxl=disabled -Dsvg=false \
	"$SRC_DIR/build" "$SRC_DIR"
ninja -C "$SRC_DIR/build"

sudo install -Dm755 "$SRC_DIR/build/wbg" /usr/local/bin/wbg
echo "build-wbg: installed wbg $WBG_VERSION -> /usr/local/bin/wbg"

#!/bin/sh
# SPDX-License-Identifier: ISC
# Copyright (C) 2026 The leonhardweiler/dotfiles Authors
#
# Build wbg from source and install the binary to /usr/local/bin/wbg. wbg is the
# wallpaper program used by the dwl session (set via config/wallpaper/
# change-wallpaper.sh). It has no runtime config, so - like dwl - the source is
# cloned at build time from a pinned tag into ~/.local/src (not committed); this
# script is the "install/update" step for wbg. Only the binary is installed
# (not `ninja install`), matching the build-dwl convention.

set -eu

WBG_VERSION="1.3.0"                # pinned upstream release tag
SRC_DIR="${WBG_SRC_DIR:-$HOME/.local/src/wbg}"

# Build/runtime dependencies. tllist is dnkl's tiny linked-list header and lives
# in the AUR, so install it via yay; the rest are official-repo packages. wbg
# also bundles nanosvg (SVG is off by default), so no nanosvg package is needed.
REPO_DEPS="pixman libpng libjpeg-turbo libwebp libjxl wayland wayland-protocols meson ninja"

if command -v pacman >/dev/null 2>&1; then
	# shellcheck disable=SC2086 # word-splitting the dep list is intended
	sudo pacman -S --needed --noconfirm $REPO_DEPS

	if ! pkg-config --exists tllist 2>/dev/null; then
		echo "build-wbg: installing tllist (AUR) via yay ..."
		yay -S --needed --noconfirm tllist
	fi
fi

# Clone (pinned) or reuse an existing checkout, always reset to a pristine tag so
# builds are reproducible.
if [ -d "$SRC_DIR/.git" ]; then
	echo "build-wbg: resetting $SRC_DIR to a pristine $WBG_VERSION ..."
	git -C "$SRC_DIR" fetch --tags --depth 1 origin "$WBG_VERSION"
	git -C "$SRC_DIR" checkout -q "$WBG_VERSION"
	git -C "$SRC_DIR" reset -q --hard "$WBG_VERSION"
else
	echo "build-wbg: cloning wbg $WBG_VERSION into $SRC_DIR ..."
	mkdir -p "$(dirname "$SRC_DIR")"
	git clone --depth 1 --branch "$WBG_VERSION" https://codeberg.org/dnkl/wbg.git "$SRC_DIR"
fi

# Configure + build (wipe any previous build dir so this stays idempotent).
rm -rf "$SRC_DIR/build"
meson setup --buildtype=release "$SRC_DIR/build" "$SRC_DIR"
ninja -C "$SRC_DIR/build"

# Install the binary only (see header comment).
sudo install -Dm755 "$SRC_DIR/build/wbg" /usr/local/bin/wbg
echo "build-wbg: installed wbg $WBG_VERSION -> /usr/local/bin/wbg"

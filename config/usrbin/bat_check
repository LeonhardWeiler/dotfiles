CAPACITY=
for bat in /sys/class/power_supply/*; do
  [ -r "$bat/type" ] && [ "$(cat "$bat/type")" = Battery ] && [ -r "$bat/capacity" ] || continue
  CAPACITY="$bat/capacity"; break
done

[ -n "$CAPACITY" ] || exit 0

PERCENT=$(cat "$CAPACITY")

case "$PERCENT" in
  ''|*[!0-9]*) exit 0 ;;
esac

if [ "$PERCENT" -lt 10 ]; then
  OSD_DURATION=5 "$(dirname "$0")/osd" "$PERCENT" critical
fi

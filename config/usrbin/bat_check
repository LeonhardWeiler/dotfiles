#!/bin/bash

CAPACITY=/sys/class/power_supply/BAT0/capacity

# No battery present (desktop, different name, removed) -> exit quietly.
[ -r "$CAPACITY" ] || exit 0

PERCENT=$(cat "$CAPACITY")

# Only continue if the value is numeric.
case "$PERCENT" in
  ''|*[!0-9]*) exit 0 ;;
esac

if [ "$PERCENT" -lt 10 ]; then
    notify-send \
      -h string:x-canonical-private-synchronous:bat \
      -h int:value:"$PERCENT" \
      "Battery" "${PERCENT}%" \
      -t 0 \
      -u critical
fi


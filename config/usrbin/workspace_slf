#!/usr/bin/env bash
# workspace_slf - sets up the complete SLF AI workspace.
#
# Target state (monitor eDP-1):
#   WS1  left: zen             | right: alacritty (claude, bypass-all) in ~/files/projects/slf
#   WS2  left: zen (review HTML + 2x localhost:5173 as tabs)
#        top right: alacritty `nvim .`   | bottom right: alacritty (shell) in slf
#   WS3  left: alacritty `nix develop` -> frontend -> `bun run dev`
#        right: alacritty `nix develop` -> backend -> `air`
#
# Behaviour: master layout, terminals always fresh, zen windows are reused or
# only added to (never closed), all other foreign windows are closed. Idempotent:
# if zen is already on the target WS, it stays.

set -o pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/home/leo/.local/bin/lib_hypr.sh
. "$DIR/lib_hypr.sh"

SLF="$HOME/files/projects/slf"
MONITOR="eDP-1"
REVIEW="file://$SLF/prompts/project-health-report.html"
DEV_URL="http://localhost:5173"

# Addresses of all windows managed by this script (for the cleanup).
MANAGED=()

require_cmds hyprctl jq alacritty zen-browser setsid

[ -d "$SLF" ] || die "project directory not found: $SLF"

# --- Self-protection ---------------------------------------------------------
# If the script is started from a terminal (tty), that window must not be closed
# during cleanup. When started via keybind there is no tty.
SELF_GUARD=""
if [ -t 2 ]; then
  SELF_GUARD="$(hyprctl activewindow -j | jq -r '.address // empty')"
fi

# --- Bind workspaces to the target monitor -----------------------------------
if hyprctl monitors -j | jq -e --arg m "$MONITOR" 'any(.[]; .name==$m)' >/dev/null; then
  for ws in 1 2 3; do
    hyprctl dispatch moveworkspacetomonitor "$ws $MONITOR" >/dev/null 2>&1
  done
else
  log "monitor $MONITOR not connected - using the current monitor."
fi

# --- Zen: WS2 (with tabs) ----------------------------------------------------
z2="$(zen_on_ws 2)"
if [ -z "$z2" ]; then
  z2="$(spawn_zen_window --new-window "$REVIEW" --new-tab "$DEV_URL" --new-tab "$DEV_URL")" \
    || die "could not open a zen window for WS2."
  move_window_to_ws "$z2" 2
fi
MANAGED+=("$z2")

# --- Zen: WS1 (normal) -------------------------------------------------------
z1="$(zen_on_ws 1)"
if [ -z "$z1" ]; then
  # Take over an existing zen window (neither on WS2 nor the WS2 window) ...
  z1="$(hyprctl clients -j \
        | jq -r --arg z2 "$z2" '.[] | select(.class=="zen" and .workspace.id!=2 and .address!=$z2) | .address' \
        | head -n1)"
  # ... otherwise open a new one.
  [ -z "$z1" ] && { z1="$(spawn_zen_window --new-window about:home)" \
    || die "could not open a zen window for WS1."; }
  move_window_to_ws "$z1" 1
fi
MANAGED+=("$z1")

# --- Terminals: always start fresh -------------------------------------------
# WS1 right: Claude Code in bypass-all mode.
a="$(spawn_alacritty "$SLF" "claude --dangerously-skip-permissions")" \
  || die "could not start terminal (WS1)."
move_window_to_ws "$a" 1
MANAGED+=("$a")

# WS2 top right: nvim.
t="$(spawn_alacritty "$SLF" "nvim .")" \
  || die "could not start nvim terminal (WS2)."
move_window_to_ws "$t" 2
MANAGED+=("$t")

# WS2 bottom right: a plain shell in the project directory.
b="$(spawn_alacritty "$SLF" "")" \
  || die "could not start shell terminal (WS2)."
move_window_to_ws "$b" 2
MANAGED+=("$b")

# WS3 left: frontend dev server in the nix shell.
f="$(spawn_alacritty "$SLF" "nix develop -c bash -ic 'cd frontend && bun run dev'")" \
  || die "could not start frontend terminal (WS3)."
move_window_to_ws "$f" 3
MANAGED+=("$f")

# WS3 right: backend (air) in the nix shell.
g="$(spawn_alacritty "$SLF" "nix develop -c bash -ic 'cd backend && air'")" \
  || die "could not start backend terminal (WS3)."
move_window_to_ws "$g" 3
MANAGED+=("$g")

# --- Close foreign windows ---------------------------------------------------
# Everything mapped except zen windows and the windows we manage ourselves.
managed_list="$(printf '%s\n' "${MANAGED[@]}")"
while read -r addr class; do
  [ -n "$addr" ] || continue
  [ "$class" = "zen" ] && continue
  case "$managed_list" in *"$addr"*) continue ;; esac
  [ -n "$SELF_GUARD" ] && [ "$addr" = "$SELF_GUARD" ] && continue
  hyprctl dispatch closewindow "address:$addr" >/dev/null 2>&1
done < <(hyprctl clients -j | jq -r '.[] | select(.mapped==true) | "\(.address) \(.class)"')

# --- Final arrangement (after the cleanup) -----------------------------------
ensure_master "$z1" 1   # WS1: zen master left, alacritty right
ensure_master "$z2" 2   # WS2: zen master left, nvim/shell stacked right
ensure_master "$f"  3   # WS3: frontend master left, backend right

focus_ws 1
log "SLF workspace set up."

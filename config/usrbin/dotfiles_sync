#
# dotfiles_sync - updates generated configs, commits changes and pushes them.
# Run at login from the dwl autostart (autostart[] in config/dwl/config.h) and
# deliberately extensible:
#   - more generators      -> extend GENERATORS
#   - more paths to version -> extend PATHS
#
# Robust: runs as a oneshot, tolerates offline/no-upstream (best-effort push)
# and exits with 0 so login is not blocked.
set -u

DOTFILES="${DOTFILES_DIR:-$HOME/dotfiles}"
SCRIPTS="${SCRIPTS_DIR:-$HOME/.local/bin}"
cd "$DOTFILES" || exit 0

# --- Generators: create/update versioned artifacts ---------------------------
# Whitespace-separated list (extend with more entries); paths must not contain
# spaces - the loop / git add rely on word splitting (intended).
GENERATORS="$SCRIPTS/update_programs_list"

# --- Paths to version (relative to the repo) ---------------------------------
PATHS="setup/programs.txt"

# shellcheck disable=SC2086 # word splitting over the whitespace-separated list is intended
for gen in $GENERATORS; do
  "$gen" || echo "dotfiles_sync: generator '$gen' failed" >&2
done

# shellcheck disable=SC2086 # word splitting over the whitespace-separated list is intended
git add -- $PATHS 2>/dev/null || true

# Only commit if something is actually staged.
if ! git diff --cached --quiet; then
  git commit -q -m "chore: automatic config sync ($(date +%F))" \
    || echo "dotfiles_sync: commit failed (signing key/passphrase?)" >&2
fi

# Best effort: only push if an upstream exists.
if git rev-parse --abbrev-ref '@{upstream}' >/dev/null 2>&1; then
  git push --quiet || echo "dotfiles_sync: push failed (offline/diverged?)" >&2
fi

exit 0

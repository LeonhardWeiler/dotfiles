STEP=5

# Check required commands (degrade quietly instead of failing cryptically).
# The OSD itself is drawn by the sibling `osd` script (ephemeral wob, no daemon).
OSD="$(dirname "$0")/osd"
for cmd in brightnessctl; do
  command -v "$cmd" >/dev/null 2>&1 || {
    echo "bright_ctl: '$cmd' not found" >&2
    exit 1
  }
done

case "$1" in
  up)
    brightnessctl set +${STEP}%
    ;;
  down)
    brightnessctl set ${STEP}%-
    ;;
  *)
    echo "Usage: $0 {up|down}"
    exit 1
    ;;
esac

CURRENT=$(brightnessctl get)
MAX=$(brightnessctl max)
PERCENT=$((CURRENT * 100 / MAX))

"$OSD" "$PERCENT"


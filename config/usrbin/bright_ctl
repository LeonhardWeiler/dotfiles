STEP=5
MIN=5   # floor: never go fully dark, and keep the bottom steps distinguishable

# Check required commands (degrade quietly instead of failing cryptically).
# The OSD itself is drawn by the sibling `osd` script (ephemeral wob, no daemon).
OSD="$(dirname "$0")/osd"
for cmd in brightnessctl; do
  command -v "$cmd" >/dev/null 2>&1 || {
    echo "bright_ctl: '$cmd' not found" >&2
    exit 1
  }
done

# Step in whole percentage points on top of the current level (rounded), then
# set an absolute value. Relative `set 5%-` bottoms out at 0 and leaves several
# low steps looking identical (a 0-4% bar is visually empty); absolute steps
# with a MIN floor keep every step distinct and never black out the screen.
MAX=$(brightnessctl max)
CURRENT=$(brightnessctl get)
PERCENT=$(( (CURRENT * 100 + MAX / 2) / MAX ))

case "$1" in
  up)   PERCENT=$((PERCENT + STEP)) ;;
  down) PERCENT=$((PERCENT - STEP)) ;;
  *)
    echo "Usage: $0 {up|down}"
    exit 1
    ;;
esac

# Clamp to [MIN, 100].
[ "$PERCENT" -gt 100 ]   && PERCENT=100
[ "$PERCENT" -lt "$MIN" ] && PERCENT=$MIN

brightnessctl set "${PERCENT}%" >/dev/null

"$OSD" "$PERCENT"


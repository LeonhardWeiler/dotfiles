set -euo pipefail

OWNER="${DOTFILES_OWNER:-$(logname 2>/dev/null || id -un)}"
OWNER_HOME="$(getent passwd "$OWNER" | cut -d: -f6)"
DOTFILES="${DOTFILES_DIR:-${OWNER_HOME:-$HOME}/dotfiles}"
OUT="$DOTFILES/setup/programs.txt"

OUT_DIR="$(dirname "$OUT")"
if [ ! -d "$OUT_DIR" ]; then
  echo "update_programs_list: $OUT_DIR missing - skipped" >&2
  exit 0
fi

TMP="$(mktemp "$OUT_DIR/.programs.txt.XXXXXX")"
trap 'rm -f "$TMP"' EXIT

pacman -Qe | awk 'NR==FNR{skip[$1];next} !($1 in skip)' <(pacman -Qq base) - > "$TMP"

chmod 644 "$TMP"
[ "$(id -u)" -eq 0 ] && chown "$OWNER" "$TMP"

mv -f "$TMP" "$OUT"
trap - EXIT

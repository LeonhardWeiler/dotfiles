#!/bin/sh
# rofi_workspace_manager — picks a workspace configuration and starts it.
# Add new configurations as another line in the list + in the case statement.

m() { rofi -dmenu -i -p "Workspace" "$@" ;}

SCRIPTS="$HOME/.local/bin"

choice="$(printf '%s\n' \
  "slf-workspace" \
  | m -l 1)"

case "$choice" in
  slf-workspace) exec "$SCRIPTS/workspace_slf" ;;
  "") exit 0 ;;
  *) rofi -e "Unknown choice: $choice"; exit 1 ;;
esac

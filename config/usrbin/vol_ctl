STEP=5

OSD="$(dirname "$0")/osd"
for cmd in pactl; do
  command -v "$cmd" >/dev/null 2>&1 || {
    echo "vol_ctl: '$cmd' not found" >&2
    exit 1
  }
done

# LC_ALL=C pins pactl's output to English - the label lookups below would
# otherwise break under a translated locale.
SINK=$(LC_ALL=C pactl info | grep "Default Sink" | awk '{print $3}')
if [ -z "$SINK" ]; then
  echo "Error: no default sink found"
  exit 1
fi

case "$1" in
  up)
    pactl set-sink-volume "$SINK" +${STEP}%
    ;;
  down)
    pactl set-sink-volume "$SINK" -${STEP}%
    ;;
  mute)
    pactl set-sink-mute "$SINK" toggle
    ;;
  *)
    echo "Usage: $0 {up|down|mute}"
    exit 1
    ;;
esac

IS_MUTED=$(LC_ALL=C pactl get-sink-mute "$SINK" | awk '{print $2}')
# grep -o with a BRE, not -oP: PCRE is a GNU-grep-only extension and this is a
# POSIX sh script.
VOLUME_RAW=$(LC_ALL=C pactl get-sink-volume "$SINK" | grep -o '[0-9]\{1,3\}%' | head -n1)
VOLUME=${VOLUME_RAW%\%}

if [ "$VOLUME" -gt 100 ]; then
  pactl set-sink-volume "$SINK" 100%
  VOLUME=100
fi

if [ "$IS_MUTED" = "yes" ]; then
  "$OSD" "$VOLUME" muted
else
  "$OSD" "$VOLUME"
fi

#!/usr/bin/env bash
set -euo pipefail

command -v restic >/dev/null 2>&1 || {
  echo "restic-backup: 'restic' nicht gefunden" >&2
  exit 1
}

# Repo/Host per Environment ueberschreibbar (portabel); Default = eigenes NAS.
export RESTIC_REPOSITORY="${RESTIC_REPOSITORY:-sftp:Leo@192.168.178.23:D:\\ResticBackup}"

restic backup \
  "$HOME/files/projects" \
  "$HOME/files/school"

echo "Cleanup? (y/n)"
read -r ans

if [ "$ans" = "y" ]; then
  restic forget --keep-daily 7 --keep-weekly 4 --keep-monthly 6 --prune
fi

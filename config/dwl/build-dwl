set -eu

DWL_VERSION="v0.8"
SRC_DIR="${DWL_SRC_DIR:-$HOME/.local/src/dwl}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_H="$SCRIPT_DIR/config.h"

[ -f "$CONFIG_H" ] || { echo "build-dwl: $CONFIG_H not found" >&2; exit 1; }

if command -v pacman >/dev/null 2>&1 && ! pacman -Q wlroots0.19 >/dev/null 2>&1; then
	echo "build-dwl: installing wlroots0.19 ..."
	sudo pacman -S --needed --noconfirm wlroots0.19
fi

if command -v pacman >/dev/null 2>&1; then
	xdeps=""
	pacman -Q libxcb        >/dev/null 2>&1 || xdeps="$xdeps libxcb"
	pacman -Q xcb-util-wm   >/dev/null 2>&1 || xdeps="$xdeps xcb-util-wm"
	pacman -Q xorg-xwayland >/dev/null 2>&1 || xdeps="$xdeps xorg-xwayland"
	if [ -n "$xdeps" ]; then
		echo "build-dwl: installing XWayland deps:$xdeps ..."
		sudo pacman -S --needed --noconfirm $xdeps
	fi
fi

if [ -d "$SRC_DIR/.git" ]; then
	echo "build-dwl: resetting $SRC_DIR to a pristine $DWL_VERSION ..."
	# Only talk to the remote when the pinned tag is not already here, and never
	# let that abort the build: config.h is applied by recompiling, so an
	# unreachable codeberg must not make editing config.h impossible.
	if ! git -C "$SRC_DIR" rev-parse -q --verify "refs/tags/$DWL_VERSION" >/dev/null; then
		git -C "$SRC_DIR" fetch --tags --depth 1 origin "$DWL_VERSION" \
			|| { echo "build-dwl: fetch failed and $DWL_VERSION is not in $SRC_DIR" >&2; exit 1; }
	fi
	git -C "$SRC_DIR" checkout -q "$DWL_VERSION"
	git -C "$SRC_DIR" reset -q --hard "$DWL_VERSION"
else
	echo "build-dwl: cloning dwl $DWL_VERSION into $SRC_DIR ..."
	mkdir -p "$(dirname "$SRC_DIR")"
	git clone --depth 1 --branch "$DWL_VERSION" https://codeberg.org/dwl/dwl.git "$SRC_DIR"
fi

for patch in "$SCRIPT_DIR"/patches/*.patch; do
	[ -e "$patch" ] || continue
	echo "build-dwl: applying $(basename "$patch") ..."
	git -C "$SRC_DIR" apply "$patch"
done

cp -f "$CONFIG_H" "$SRC_DIR/config.h"
make -C "$SRC_DIR" clean >/dev/null 2>&1 || true
make -C "$SRC_DIR" XWAYLAND=-DXWAYLAND XLIBS="xcb xcb-icccm"

sudo install -Dm755 "$SRC_DIR/dwl" /usr/local/bin/dwl
echo "build-dwl: installed $(/usr/local/bin/dwl -v 2>&1 | head -1) -> /usr/local/bin/dwl"

#
# dwl session entry point. There is no display manager: getty@tty1 autologins
# `leo` and ~/.bash_profile execs this on tty1. dwl has no config file for
# environment variables, so the scaling/cursor environment is exported here
# before dwl starts. XDG_CURRENT_DESKTOP and QT_QPA_PLATFORMTHEME come from
# ~/.bash_profile (the autologin login shell), so they are not duplicated here.

# export QT_SCALE_FACTOR=1.6
# export QT_AUTO_SCREEN_SCALE_FACTOR=0
# export GDK_SCALE=2
# export XCURSOR_SIZE=18

exec dwl

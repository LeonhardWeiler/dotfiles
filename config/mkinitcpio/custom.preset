# mkinitcpio preset file for the custom-built kernel (vmlinuz-custom).
# ALL_kver points at the kernel image so mkinitcpio reads the version from it
# (mirrors linux.preset), staying correct across custom-kernel rebuilds.

#ALL_config="/etc/mkinitcpio.conf"
ALL_kver="7.1.3-arch2-2"

PRESETS=('default')

#default_config="/etc/mkinitcpio.conf"
default_image="/efi/initramfs-custom.img"

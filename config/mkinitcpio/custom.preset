# mkinitcpio preset file for the custom-built kernel (vmlinuz-custom-r17).
# ALL_kver points at the kernel image so mkinitcpio reads the version from it
# (mirrors linux.preset), staying correct across custom-kernel rebuilds.
# NB: die ESP (FAT) kann keine Symlinks, darum zeigt das Preset auf die
# versioniert benannte Kernel-Datei; bei einem neuen Bau (r18…) hier + im
# Booteintrag (arch-custom-rNN.conf) den Suffix nachziehen.

#ALL_config="/etc/mkinitcpio.conf"
ALL_kver="/efi/vmlinuz-custom-r17"

PRESETS=('default')

#default_config="/etc/mkinitcpio.conf"
default_image="/efi/initramfs-custom-r17.img"

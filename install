#!/usr/bin/env bash
# SPDX-License-Identifier: ISC
# Copyright (C) 2026 The leonhardweiler/dotfiles Authors
#
# Symlink manager for these dotfiles - no external dependencies.
# Reads the mapping file `links.conf` (source -> target) and creates the
# symlinks, removes them again, or shows their current state.
#
# Keep this lean: new config is a line in links.conf, not code here. Prefer
# deleting a feature over growing this file - resist feature creep.
#
# Usage:
#   ./install [link]          create/refresh symlinks (default, everyday)
#   ./install setup           fresh machine, ONE command: optional steps (menu)
#                             -> link configs (--force) -> activate units
#   ./install unlink          remove the symlinks we manage
#   ./install status          show the current state of every entry
#   ./install validate        check links.conf without touching the filesystem
#
# Optional setup steps (selectable in the `setup` menu, runnable individually via
# a flag for automation - e.g. `./install --groups` or
# `./install setup --timezone Europe/Vienna`). The list is printed by
# `./install --help`, generated from the register_step registry below - so a new
# step is a single register_step call and nothing else.
#
# Options:
#   -n, --dry-run             only show what would happen - change nothing
#   -c, --config FILE         other mapping file (default: setup/links.conf)
#       --user-only           only ~ targets (no /etc targets, no sudo)
#       --no-units            do not (re)activate the systemd units
#       --force               back up real files/dirs at the target to .bak and
#                             replace them with the symlink
#   -h, --help                this help
set -euo pipefail

BASEDIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG="setup/links.conf"
CMD="link"
EXPLICIT_CMD=0       # was a subcommand typed explicitly?
DRYRUN=0
USER_ONLY=0
NO_UNITS=0
FORCE=0
SKIPPED_REAL=0       # number of skipped real targets (without --force) - for the closing hint
FLAG_STEPS_GIVEN=0   # was at least one --<step> flag passed?
TIMEZONE=""          # optional --timezone value (Region/City)

# systemd units to (re)activate are kept out of the script in setup/services.txt
# and loaded into USER_UNITS/SYSTEM_UNITS just below (after the output helpers).

# ── Output helpers ───────────────────────────────────────────────────────────
if [ -t 1 ]; then C_OK=$'\e[32m'; C_WARN=$'\e[33m'; C_INFO=$'\e[36m'; C_RST=$'\e[0m'
else C_OK=; C_WARN=; C_INFO=; C_RST=; fi
ok()   { printf '  %s✔%s %s\n'  "$C_OK"   "$C_RST" "$*"; }
warn() { printf '  %s!%s %s\n'  "$C_WARN" "$C_RST" "$*" >&2; }
info() { printf '%sℹ %s%s\n'    "$C_INFO" "$*"     "$C_RST"; }

# Help = the header comment block plus the step list generated from the registry
# (STEP_ORDER/STEP_DESC), so the steps cannot drift out of sync with the code.
usage() {
  awk 'NR>1{ if ($0 !~ /^#/) exit; sub(/^# ?/,""); print }' "$0"
  if [ "${#STEP_ORDER[@]}" -gt 0 ]; then
    printf 'Optional setup steps:\n'
    local s
    for s in "${STEP_ORDER[@]}"; do
      printf '  --%-23s %s\n' "$s${STEP_ARG[$s]:+ ${STEP_ARG[$s]}}" "${STEP_DESC[$s]}"
    done
  fi
  exit "${1:-0}"
}

# ── Data lists (kept out of the script, in setup/*.txt) ──────────────────────
# systemd units, split by scope (`user`/`system`/`disable`/`mask`) -> USER_UNITS
# / SYSTEM_UNITS / DISABLE_UNITS / MASK_UNITS. `disable` = a preset-enabled
# system unit we want OFF at boot (e.g. NetworkManager-wait-online); `mask` = a static/always-on unit we want fully blocked - it has no
# [Install] so `disable` is a no-op, and masking also defeats udev-triggered
# starts (e.g. systemd-vconsole-setup via 90-vconsole.rules).
USER_UNITS=(); SYSTEM_UNITS=(); DISABLE_UNITS=(); MASK_UNITS=()
read_services() {
  local file="$1" line scope unit
  [ -f "$file" ] || { warn "services list missing: $file"; return 0; }
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"; read -r scope unit _ <<<"$line" || true
    [ -z "${scope:-}" ] && continue
    case "$scope" in
      user)    [ -n "${unit:-}" ] && USER_UNITS+=("$unit") ;;
      system)  [ -n "${unit:-}" ] && SYSTEM_UNITS+=("$unit") ;;
      disable) [ -n "${unit:-}" ] && DISABLE_UNITS+=("$unit") ;;
      mask)    [ -n "${unit:-}" ] && MASK_UNITS+=("$unit") ;;
      *) warn "$file: unknown scope '$scope' (expected user|system|disable|mask)" ;;
    esac
  done < "$file"
}
read_services "$BASEDIR/setup/services.txt"

# Generic list reader: one value per line (`#` comments / blanks ignored) into
# the named array (Bash nameref).
read_list() {
  local file="$1"; local -n __out="$2"; local line val
  __out=()
  [ -f "$file" ] || { warn "list file missing: $file"; return 0; }
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"; read -r val _ <<<"$line" || true
    [ -z "${val:-}" ] && continue
    __out+=("$val")
  done < "$file"
}

# Groups for --groups, joined into a comma list for `usermod -aG`.
GROUP_ARR=()
read_list "$BASEDIR/setup/groups.txt" GROUP_ARR
GROUP_LIST="$(IFS=,; printf '%s' "${GROUP_ARR[*]}")"

# Font packages for --fonts.
FONT_PACKAGES=()
read_list "$BASEDIR/setup/fonts.txt" FONT_PACKAGES

# ── Optional setup steps (registry) ──────────────────────────────────────────
# Each step has a do_<name> function, a `--<name>` flag and a menu line in
# `setup`. New steps are added below via register_step. SELECTED holds the
# currently chosen steps.
STEP_ORDER=()
declare -A STEP_DESC STEP_FN STEP_ARG SELECTED
# Steps preselected in `setup` (menu Enter / no TTY = these defaults).
DEFAULT_STEPS=(programs systemd locale)
# register_step <name> <fn> <description> [<arg-placeholder>]
# The registry is the single source of truth: the `--<name>` flag, the help text
# and the `setup` menu entry all come from here. The optional 4th field names the
# value a step's flag takes (only --timezone has one).
register_step() { STEP_ORDER+=("$1"); STEP_FN[$1]="$2"; STEP_DESC[$1]="$3"; STEP_ARG[$1]="${4:-}"; }
is_selected()   { [ -n "${SELECTED[$1]:-}" ]; }

# Interactive yes/no prompt. Without a TTY (scriptable) always "no".
confirm() {
  local reply
  [ -t 0 ] || return 1
  printf '%s [y/N] ' "$1" >&2
  read -r reply || return 1
  case "$reply" in [yYjJ]*) return 0 ;; *) return 1 ;; esac
}

# ── Path helpers ─────────────────────────────────────────────────────────────
# `~` -> the user's home.
expand_target() {
  case "$1" in
    "~")    printf '%s\n' "$HOME" ;;
    "~/"*)  printf '%s\n' "$HOME/${1#\~/}" ;;
    *)      printf '%s\n' "$1" ;;
  esac
}
# Target outside $HOME -> needs root.
needs_root() { case "$1" in "$HOME"/*|"$HOME") return 1 ;; *) return 0 ;; esac; }

# `run <root?> cmd…` - run a command (via sudo if needed), honouring dry-run.
run() {
  local root="$1"; shift
  if [ "$DRYRUN" = 1 ]; then
    printf '    [dry] %s%s\n' "$([ "$root" = 1 ] && printf 'sudo ')" "$*"
    return 0
  fi
  if [ "$root" = 1 ]; then sudo "$@"; else "$@"; fi
}

# ── Per-entry actions ────────────────────────────────────────────────────────
# Resolve one table entry (<source-rel> <target-spec>) into the values every
# per-entry action needs, published in PT_SRC / PT_TARGET / PT_ROOT. Returns
# non-zero when the entry must be skipped under --user-only (a root target), so
# mutating callers can fold the skip in:  prepare_target "$1" "$2" || return 0
# (status is read-only and shows every entry, so it ignores the skip).
prepare_target() {
  PT_SRC="$BASEDIR/$1"
  PT_TARGET="$(expand_target "$2")"
  PT_ROOT=0; needs_root "$PT_TARGET" && PT_ROOT=1
  { [ "$USER_ONLY" = 1 ] && [ "$PT_ROOT" = 1 ]; } && return 1
  return 0
}

link_one() {
  local rel="$1"; prepare_target "$1" "$2" || return 0
  local src="$PT_SRC" target="$PT_TARGET" root="$PT_ROOT"
  if [ ! -e "$src" ]; then warn "source missing, skipped: $rel"; return 0; fi
  if [ -e "$target" ] && [ ! -L "$target" ]; then
    if [ "$FORCE" = 1 ]; then
      local bak="$target.bak"
      if [ -e "$bak" ]; then bak="$target.bak.$(date +%s)"; fi
      run "$root" mv "$target" "$bak"; ok "backed up: $target -> $bak"
    else
      warn "real file/directory, skipped (use --force to back up & replace): $target"
      SKIPPED_REAL=$((SKIPPED_REAL + 1)); return 0
    fi
  fi
  local parent; parent="$(dirname "$target")"
  # A dead (broken) symlink as the parent path - e.g. left over from an old
  # setup - would otherwise make `mkdir -p` fail with "File exists" and abort the
  # whole run under `set -e`. A dead symlink has no content -> safe to remove
  # (only real, dangling symlinks; real files/dirs are left untouched).
  if [ -L "$parent" ] && [ ! -e "$parent" ]; then run "$root" rm -f "$parent"; fi
  if [ ! -d "$parent" ]; then
    run "$root" mkdir -p "$parent" \
      || { warn "parent path not creatable, skipped: $parent"; return 0; }
  fi
  run "$root" ln -sfn "$src" "$target"
  ok "$2 -> $rel"
}

unlink_one() {
  prepare_target "$1" "$2" || return 0
  local src="$PT_SRC" target="$PT_TARGET" root="$PT_ROOT"
  if [ -L "$target" ]; then
    if [ "$(readlink "$target")" = "$src" ]; then
      run "$root" rm "$target"; ok "removed: $2"
    else
      warn "symlink points elsewhere (kept): $target"
    fi
  elif [ -e "$target" ]; then
    warn "not a symlink (kept): $target"
  fi
}

status_one() {
  prepare_target "$1" "$2" || :   # read-only: report every entry, incl. root ones
  local src="$PT_SRC" target="$PT_TARGET" state
  if [ -L "$target" ]; then
    if [ "$(readlink "$target")" = "$src" ]; then state="${C_OK}ok${C_RST}"
    else state="${C_WARN}link->$(readlink "$target")${C_RST}"; fi
  elif [ -e "$target" ]; then state="${C_WARN}real file${C_RST}"
  else state="missing"; fi
  printf '  %-46s %s\n' "$2" "$state"
}

# ── Optional step functions ──────────────────────────────────────────────────
# Install packages from setup/programs.txt. Delegates to setup/install-programs
# (bootstraps yay from the AUR if needed; skips already-installed packages). Runs
# BEFORE linking so the units reactivated afterwards exist.
do_programs_install() {
  local script="$BASEDIR/setup/install-programs"
  [ -x "$script" ] || { warn "setup/install-programs missing/not executable: $script"; return 0; }
  info "Installing packages from setup/programs.txt (yay)"
  if [ "$DRYRUN" = 1 ]; then printf '    [dry] %s\n' "$script"; return 0; fi
  "$script" || warn "package installation not (fully) successful"
}
register_step programs do_programs_install "Install packages from programs.txt"

# Closing hint after linking: report skipped real targets prominently and remind
# the user to apply the freshly linked shell config. (A script cannot reload the
# interactive parent shell itself - hence the explicit hint instead of a useless
# `source` inside the script.)
next_steps() {
  if [ "$SKIPPED_REAL" -gt 0 ]; then
    warn "$SKIPPED_REAL real target(s) skipped - use './install --force' to back up to .bak and replace."
  fi
  [ "$DRYRUN" = 1 ] && return 0
  info "Next steps"
  printf '  • %ssource ~/.bashrc%s  - apply the shell config now (also loads ~/.nix-profile via nix.sh)\n' "$C_OK" "$C_RST"
  printf '  • log in again once for the .bash_profile env (GTK_THEME, QT_QPA_PLATFORMTHEME, XDG_*)\n'
  # After the fresh-machine setup, several changes (system units, initramfs,
  # groups, timezone, locale) only take full effect after a reboot.
  if [ "$CMD" = setup ]; then
    printf '  • %sreboot your PC%s to fully apply system units, initramfs, groups, timezone and locale\n' "$C_WARN" "$C_RST"
  fi
}

# Generate the freshly linked locales (/etc/locale.gen), idempotent.
do_locale() {
  if [ "$USER_ONLY" = 1 ]; then warn "--user-only: locale-gen skipped"; return 0; fi
  info "Generating locales (locale-gen)"
  run 1 locale-gen || warn "locale-gen failed"
}
register_step locale do_locale "Generate locales (locale-gen)"

# Apply the menu preselection (DEFAULT_STEPS) - used without a TTY or on empty input.
select_defaults() { local s; for s in "${DEFAULT_STEPS[@]}"; do SELECTED[$s]=1; done; }

# Interactive menu: pick optional steps. With steps preselected via flags
# (FLAG_STEPS_GIVEN) it takes them as-is; without a TTY the DEFAULT_STEPS apply.
choose_steps() {
  [ "$FLAG_STEPS_GIVEN" = 1 ] && return 0
  if [ ! -t 0 ]; then select_defaults; return 0; fi
  info "Select optional steps (numbers separated by spaces; Enter = defaults)"
  local i=1 idx=() def
  for s in "${STEP_ORDER[@]}"; do
    in_array "$s" "${DEFAULT_STEPS[@]}" && def=" (default)" || def=""
    printf '  [%d] %s%s\n' "$i" "${STEP_DESC[$s]}" "$def"; idx[$i]="$s"; i=$((i+1))
  done
  # Loop until the input actually selects something: silently dropping a typo
  # (`99`, a step name, `1,2` when the prompt asks for spaces) used to run zero
  # steps and still report success.
  local line n hit
  while :; do
    printf '> '; read -r line || line=""
    if [ -z "$line" ]; then select_defaults; return 0; fi
    hit=0
    for n in ${line//,/ }; do
      case "$n" in
        # Not a number: accept the step name too, that is what people type.
        # (Also keeps arbitrary text out of the arithmetic array subscript.)
        ''|*[!0-9]*)
          if [ -n "${STEP_FN[$n]:-}" ]; then SELECTED[$n]=1; hit=1
          else warn "unknown selection: $n"; fi ;;
        *)
          if [ -n "${idx[$n]:-}" ]; then SELECTED[${idx[$n]}]=1; hit=1
          else warn "unknown selection: $n"; fi ;;
      esac
    done
    [ "$hit" = 1 ] && return 0
    warn "nothing selected - enter numbers from the list, or press Enter for the defaults"
  done
}

# Linking core (symlinks only). Package/unit steps run separately.
do_symlinks() {
  info "Creating symlinks (${#SRCS[@]} entries)"
  for i in "${!SRCS[@]}"; do link_one "${SRCS[$i]}" "${TGTS[$i]}"; done
}

reactivate_units() {
  [ "$NO_UNITS" = 1 ] && return 0
  # Deliberately `enable`, not `reenable`: our unit files are symlinks (linked
  # units); `reenable` would delete exactly that unit symlink during its internal
  # `disable`. `enable` is idempotent and only creates the missing enablement
  # link (…​.wants/) - it also survives a repo move because the unit symlink sits
  # at the standard path.
  info "Activating systemd user units"
  run 0 systemctl --user daemon-reload || warn "daemon-reload failed"
  for u in "${USER_UNITS[@]}"; do
    if [ "$DRYRUN" = 1 ]; then run 0 systemctl --user enable "$u"
    else run 0 systemctl --user enable "$u" >/dev/null 2>&1 || warn "user unit not activated: $u"; fi
  done
  [ "$USER_ONLY" = 1 ] && return 0
  info "Activating systemd system units (sudo)"
  for u in "${SYSTEM_UNITS[@]}"; do
    if [ "$DRYRUN" = 1 ]; then run 1 systemctl enable "$u"
    else run 1 systemctl enable "$u" >/dev/null 2>&1 || warn "system unit not activated: $u"; fi
  done
  # Preset-enabled units we want OFF at boot (shave startup time). `disable` is
  # idempotent; a unit that does not exist just warns.
  [ ${#DISABLE_UNITS[@]} -gt 0 ] && info "Disabling boot-time system units (sudo)"
  for u in "${DISABLE_UNITS[@]}"; do
    if [ "$DRYRUN" = 1 ]; then run 1 systemctl disable "$u"
    else run 1 systemctl disable "$u" >/dev/null 2>&1 || warn "system unit not disabled: $u"; fi
  done
  # Static/always-on units we want fully off: no [Install] means `disable` cannot
  # touch them, so `mask` them (symlink to /dev/null) - this also blocks starts
  # triggered by udev rules. Idempotent; unmask by hand to revert.
  [ ${#MASK_UNITS[@]} -gt 0 ] && info "Masking system units (sudo)"
  for u in "${MASK_UNITS[@]}"; do
    if [ "$DRYRUN" = 1 ]; then run 1 systemctl mask "$u"
    else run 1 systemctl mask "$u" >/dev/null 2>&1 || warn "system unit not masked: $u"; fi
  done
}
register_step systemd reactivate_units "Activate systemd units (enable)"

# Add the user to the groups the tracked tools need. GROUP_LIST is loaded from
# setup/groups.txt near the top (Bash reserves `GROUPS` for the current GIDs).
do_groups() {
  local user="${SUDO_USER:-${USER:-}}"
  [ -n "$user" ] || { warn "no user determinable - groups skipped"; return 0; }
  [ -n "$GROUP_LIST" ] || { warn "no groups configured (setup/groups.txt) - skipped"; return 0; }
  info "Adding user '$user' to groups: $GROUP_LIST"
  run 1 usermod -aG "$GROUP_LIST" "$user" || warn "usermod failed"
  info "(group change takes effect after re-login)"
}
register_step groups do_groups "Add user to groups ($GROUP_LIST)"

# Set the timezone via the symlink /etc/localtime -> /usr/share/zoneinfo/<zone>.
# Zone from --timezone or (in the menu) asked interactively.
do_timezone() {
  local tz="$TIMEZONE"
  if [ -z "$tz" ] && [ -t 0 ]; then
    printf '  Timezone (Region/City, e.g. Europe/Vienna): ' >&2; read -r tz || tz=""
  fi
  [ -n "$tz" ] || { warn "no timezone given - skipped"; return 0; }
  if [ ! -e "/usr/share/zoneinfo/$tz" ]; then warn "unknown timezone: $tz - skipped"; return 0; fi
  info "Setting timezone: $tz"
  run 1 ln -sf "/usr/share/zoneinfo/$tz" /etc/localtime || warn "setting timezone failed"
}
register_step timezone do_timezone "Set timezone (/etc/localtime)" ZONE

# Deploy the getty@tty1 autologin drop-in as a REAL copy onto the root partition
# (not symlinked via links.conf): systemd reads unit drop-ins early at manager
# start, when a /home symlink would still be a dead link. Then daemon-reload.
# This is what logs `leo` into the dwl session at boot without a display manager.
GETTY_DROPIN_DIR="/etc/systemd/system/getty@tty1.service.d"
do_getty_autologin() {
  local src="$BASEDIR/config/systemd-system/getty@tty1.service.d"
  [ -d "$src" ] || { warn "getty@tty1 drop-in source missing: $src"; return 0; }
  info "Copying getty@tty1 autologin drop-in to $GETTY_DROPIN_DIR"
  run 1 install -d -m755 "$GETTY_DROPIN_DIR" || { warn "directory not creatable"; return 0; }
  run 1 install -m644 "$src"/autologin.conf "$GETTY_DROPIN_DIR"/ \
    || warn "drop-in copy failed"
  run 1 systemctl daemon-reload || warn "daemon-reload failed"
}
register_step getty-autologin do_getty_autologin "Deploy getty@tty1 autologin drop-in (real copy)"

# Passwordless sudo for the wheel group - a deliberate convenience choice of this
# setup. As a drop-in in /etc/sudoers.d/ (0440), first checked with `visudo -c`
# on a temp file so broken sudoers syntax cannot lock you out of the system.
do_sudoers() {
  local file="/etc/sudoers.d/10-wheel-nopasswd"
  local rule="%wheel ALL=(ALL:ALL) NOPASSWD: ALL"
  info "Setting up passwordless sudo for wheel: $file"
  if [ "$DRYRUN" = 1 ]; then
    printf "    [dry] printf '%s' | visudo -c && sudo install -m0440 -> %s\n" "$rule" "$file"; return 0
  fi
  local tmp; tmp="$(mktemp)"; printf '%s\n' "$rule" > "$tmp"
  if ! visudo -cf "$tmp" >/dev/null 2>&1; then
    warn "sudoers syntax invalid - skipped"; rm -f "$tmp"; return 0
  fi
  run 1 install -m0440 -o root -g root "$tmp" "$file" || warn "sudoers file not installed"
  rm -f "$tmp"
}
register_step sudoers do_sudoers "Passwordless sudo for wheel (sudoers.d)"

# Rebuild the initramfs (mkinitcpio -P) - needed after changes to
# /etc/mkinitcpio.conf (linked via links.conf).
do_initramfs() {
  command -v mkinitcpio >/dev/null 2>&1 || { warn "mkinitcpio missing - skipped"; return 0; }
  info "Regenerating initramfs (mkinitcpio -P)"
  run 1 mkinitcpio -P || warn "mkinitcpio failed"
}
register_step initramfs do_initramfs "Regenerate initramfs (mkinitcpio -P)"

# Install the font packages (loaded from setup/fonts.txt near the top) and rebuild
# the fontconfig cache so freshly installed fonts are picked up without a re-login.
do_fonts() {
  [ "${#FONT_PACKAGES[@]}" -gt 0 ] || { warn "no fonts configured (setup/fonts.txt) - skipped"; return 0; }
  info "Installing fonts and refreshing the font cache: ${FONT_PACKAGES[*]}"
  if [ "$DRYRUN" = 1 ]; then
    printf '    [dry] yay -S --needed --noconfirm %s\n' "${FONT_PACKAGES[*]}"
    printf '    [dry] fc-cache -f\n'; return 0
  fi
  if command -v yay >/dev/null 2>&1; then
    yay -S --needed --noconfirm "${FONT_PACKAGES[@]}" || warn "font install not (fully) successful"
  elif command -v pacman >/dev/null 2>&1; then
    sudo pacman -S --needed --noconfirm "${FONT_PACKAGES[@]}" || warn "font install not (fully) successful"
  else
    warn "no package manager - font install skipped"
  fi
  if command -v fc-cache >/dev/null 2>&1; then fc-cache -f || warn "fc-cache failed"
  else warn "fc-cache missing - font cache not refreshed"; fi
}
register_step fonts do_fonts "Install fonts + refresh font cache (fc-cache)"

# Enable the Lenovo Legion battery conservation mode (charge stops at ~60%).
# The ideapad_acpi driver writes the flag through to the embedded controller,
# which keeps it across reboots and power-offs - so this is a one-shot setup
# step, not something that has to run on every boot (it used to be a
# legion-conservation.service run at every multi-user.target). Not a default
# step: it is Legion hardware specific.
LEGION_CONSERVATION=/sys/bus/platform/drivers/ideapad_acpi/VPC2004:00/conservation_mode
do_legion_conservation() {
  [ -e "$LEGION_CONSERVATION" ] || {
    warn "no ideapad conservation_mode (not a Legion?) - skipped"; return 0; }
  if [ "$(cat "$LEGION_CONSERVATION" 2>/dev/null)" = 1 ]; then
    info "Battery conservation mode already enabled - nothing to do"; return 0
  fi
  info "Enabling battery conservation mode ($LEGION_CONSERVATION)"
  if [ "$DRYRUN" = 1 ]; then
    printf "    [dry] sudo sh -c 'echo 1 > %s'\n" "$LEGION_CONSERVATION"; return 0
  fi
  # tee, not a redirect: the redirect would be opened by our unprivileged shell.
  printf '1\n' | sudo tee "$LEGION_CONSERVATION" >/dev/null \
    || warn "could not enable conservation mode"
}
register_step legion-conservation do_legion_conservation \
  "Enable Legion battery conservation mode (persists in the EC, one-shot)"

# Build + install dwl (compiled-config Wayland compositor) from the tracked
# config/dwl/config.h. dwl is configured at compile time, so this IS the "apply"
# step for config/dwl changes; delegates to config/dwl/build-dwl (clone/pin dwl,
# drop in config.h, make, install the binary to /usr/local/bin). Not a default
# step - only needed on a fresh machine or after editing config/dwl/config.h.
do_dwl() {
  local script="$BASEDIR/config/dwl/build-dwl"
  [ -x "$script" ] || { warn "config/dwl/build-dwl missing - skipped"; return 0; }
  info "Building + installing dwl (config/dwl/build-dwl)"
  run 0 "$script" || warn "dwl build failed"
}
register_step dwl do_dwl "Build + install dwl from config/dwl/config.h"

# Build + install wbg (the wallpaper program used by change-wallpaper.sh) from a
# pinned upstream tag; delegates to config/wbg/build-wbg (clone/pin, meson/ninja,
# install the binary to /usr/local/bin). Not a default step - only needed on a
# fresh machine.
do_wbg() {
  local script="$BASEDIR/config/wbg/build-wbg"
  [ -x "$script" ] || { warn "config/wbg/build-wbg missing - skipped"; return 0; }
  info "Building + installing wbg (config/wbg/build-wbg)"
  run 0 "$script" || warn "wbg build failed"
}
register_step wbg do_wbg "Build + install wbg (wallpaper program) from source"

# ── Argument parsing ─────────────────────────────────────────────────────────
# Runs AFTER the register_step calls above, so the step flags can be matched
# against the registry instead of a hand-maintained list.
while [ $# -gt 0 ]; do
  case "$1" in
    link|setup|unlink|status|validate) CMD="$1"; EXPLICIT_CMD=1 ;;
    -n|--dry-run)  DRYRUN=1 ;;
    --user-only)   USER_ONLY=1 ;;
    --no-units)    NO_UNITS=1 ;;
    --force)       FORCE=1 ;;
    -c|--config)   shift; CONFIG="${1:?--config needs a file}" ;;
    -h|--help)     usage 0 ;;
    # --timezone is the one step whose flag carries a value (STEP_ARG).
    --timezone)    shift; TIMEZONE="${1:?--timezone needs a zone (Region/City)}"
                   SELECTED[timezone]=1; FLAG_STEPS_GIVEN=1 ;;
    # Every registered optional step is its own `--<name>` flag - no separate
    # list to keep in sync, register_step is enough.
    --*) step="${1#--}"
         if [ -n "${STEP_FN[$step]:-}" ]; then SELECTED[$step]=1; FLAG_STEPS_GIVEN=1
         else warn "unknown argument: $1"; usage 1; fi ;;
    *) warn "unknown argument: $1"; usage 1 ;;
  esac
  shift
done

# No explicit subcommand but step flags given -> run only those steps
# (scriptable, no linking, no menu).
if [ "$EXPLICIT_CMD" = 0 ] && [ "$FLAG_STEPS_GIVEN" = 1 ]; then
  CMD="run-steps"
fi

[ -f "$BASEDIR/$CONFIG" ] || { warn "mapping file not found: $CONFIG"; exit 1; }

# ── links.conf pipeline: parse -> validate -> build (globs) -> execute ────────
# Explicit phases so execution never sees a malformed entry: the raw entries
# (verbatim from the file, no globbing) are validated first; only then is the
# work table (SRCS/TGTS) built by expanding globs. Read fully first - otherwise a
# sudo password prompt collides with the read loop's stdin.
RAW_SRC=(); RAW_TGT=(); RAW_OPT=(); RAW_LN=()

# Phase 1 - parse: read the file into raw arrays (source, target, 3rd field, line
# number). No filesystem access and no globbing here.
parse_links() {
  local ln=0 line s t extra
  while IFS= read -r line || [ -n "$line" ]; do
    ln=$((ln + 1))
    line="${line%%#*}"                 # strip the comment from # onwards
    read -r s t extra <<<"$line" || true
    [ -z "${s:-}" ] && continue        # blank or comment-only line
    RAW_SRC+=("$s"); RAW_TGT+=("${t:-}"); RAW_OPT+=("${extra:-}"); RAW_LN+=("$ln")
  done < "$BASEDIR/$CONFIG"
}

# Report a validation problem at a specific links.conf line.
verr() { printf '  %s✗%s %s:%s: %s\n' "$C_WARN" "$C_RST" "$CONFIG" "$1" "$2" >&2; }

# Target prefix allowlist: a target must live under one of these (add a prefix
# here to opt one in). Keeps a stray `/tmp/...`, `/usr/...` or `/` target - which
# would write outside the intended user/system config areas - out of the config.
ALLOWED_TARGET_PREFIXES=("$HOME" "/etc" "/usr/local")

# Phase 2 - validate: check the raw entries and collect ALL problems (no
# filesystem mutation). Returns non-zero if anything is wrong. Every command runs
# this before touching the filesystem, so a broken config aborts the whole run
# instead of silently skipping lines.
validate_links() {
  local i s t opt ln tgt m et ok p matched errs=0
  local -A seen_tgt
  if [ "${#RAW_SRC[@]}" -eq 0 ]; then warn "$CONFIG: no entries"; return 1; fi
  for i in "${!RAW_SRC[@]}"; do
    s="${RAW_SRC[$i]}"; t="${RAW_TGT[$i]}"; opt="${RAW_OPT[$i]}"; ln="${RAW_LN[$i]}"
    # A well-formed line is exactly `<source> <target>`.
    if [ -z "$t" ]; then verr "$ln" "missing target for source '$s'"; errs=1; continue; fi
    # The only allowed 3rd field is the `optional` keyword (marks a source - a
    # glob in particular - that may legitimately match nothing).
    if [ -n "$opt" ] && [ "$opt" != optional ]; then
      verr "$ln" "unexpected extra field(s) '$opt' (expected: <source> <target> [optional])"; errs=1
    fi
    # Source must be a repo-relative path (not absolute).
    case "$s" in
      /*) verr "$ln" "source must be relative to the repo: '$s'"; errs=1 ;;
    esac
    # Source must exist (a glob is checked via its match count below; `optional`
    # allows a missing non-glob source too). Skipped for absolute sources - those
    # are already reported above.
    if [[ "$s" != /* ]] && [[ "$s" != *"*"* ]] && [ ! -e "$BASEDIR/$s" ] && [ "$opt" != optional ]; then
      verr "$ln" "source does not exist: '$s'"; errs=1
    fi
    tgt="$(expand_target "$t")"
    # Target must sit under an allowed prefix (~ / /etc / /usr/local).
    ok=0
    for p in "${ALLOWED_TARGET_PREFIXES[@]}"; do
      case "$tgt/" in "$p"/*) ok=1; break ;; esac
    done
    if [ "$ok" != 1 ]; then
      verr "$ln" "target prefix not allowed: '$t' (allowed: ~ /etc /usr/local)"; errs=1
    fi
    # Duplicate target: compare the FINAL (expanded) targets so two entries never
    # fight over the same path. Globs are expanded per match here.
    if [[ "$s" == *"*"* ]]; then
      matched=0
      shopt -s nullglob
      for m in "$BASEDIR"/$s; do
        matched=1
        et="${tgt%/}/${m##*/}"
        if [ -n "${seen_tgt[$et]:-}" ]; then
          verr "$ln" "duplicate target '$et' (first seen at line ${seen_tgt[$et]})"; errs=1
        else seen_tgt[$et]="$ln"; fi
      done
      shopt -u nullglob
      # An unmatched glob is fatal unless the entry is marked `optional`.
      if [ "$matched" = 0 ] && [ "$opt" != optional ]; then
        verr "$ln" "glob matches nothing: '$s' (append 'optional' to allow zero matches)"; errs=1
      fi
    else
      if [ -n "${seen_tgt[$tgt]:-}" ]; then
        verr "$ln" "duplicate target '$tgt' (first seen at line ${seen_tgt[$tgt]})"; errs=1
      else seen_tgt[$tgt]="$ln"; fi
    fi
  done
  return "$errs"
}

# Phase 3 - build: expand globs into the work table SRCS/TGTS. A glob source
# (e.g. `config/usrbin/*`) links every match individually into <target>/<name>,
# so the target directory stays real and foreign entries in it are preserved.
build_table() {
  SRCS=(); TGTS=()
  local i s t m
  for i in "${!RAW_SRC[@]}"; do
    s="${RAW_SRC[$i]}"; t="${RAW_TGT[$i]}"
    if [[ "$s" == *"*"* ]]; then
      shopt -s nullglob
      for m in "$BASEDIR"/$s; do SRCS+=("${m#"$BASEDIR"/}"); TGTS+=("${t%/}/${m##*/}"); done
      shopt -u nullglob
    else
      SRCS+=("$s"); TGTS+=("$t")
    fi
  done
}

in_array() { local x="$1"; shift; local e; for e in "$@"; do [ "$e" = "$x" ] && return 0; done; return 1; }

SRCS=(); TGTS=()
parse_links
# `validate` subcommand: report and stop, without building or executing.
if [ "$CMD" = validate ]; then
  if validate_links; then
    info "$CONFIG: valid (${#RAW_SRC[@]} entries)"; exit 0
  else
    warn "$CONFIG: validation failed"; exit 1
  fi
fi
if ! validate_links; then
  warn "$CONFIG is invalid - aborting (nothing changed). Run './install validate' to list the problems."
  exit 1
fi
build_table
[ "${#SRCS[@]}" -gt 0 ] || { warn "no entries in $CONFIG"; exit 1; }

# ── Execution ────────────────────────────────────────────────────────────────
[ "$DRYRUN" = 1 ] && info "- Dry run: nothing is changed -"
case "$CMD" in
  link)
    do_symlinks
    reactivate_units
    next_steps
    ;;
  setup)
    # One-command bootstrap for a fresh machine.
    FORCE=1
    info "Setup: optional steps -> link (--force) -> units"
    choose_steps
    is_selected programs && do_programs_install
    do_symlinks
    is_selected systemd && reactivate_units
    is_selected groups && do_groups
    is_selected timezone && do_timezone
    is_selected getty-autologin && do_getty_autologin
    is_selected sudoers && do_sudoers
    is_selected initramfs && do_initramfs
    is_selected fonts && do_fonts
    is_selected locale && do_locale
    next_steps
    ;;
  run-steps)
    # Only the optional steps chosen via flags (scriptable), in canonical order.
    for s in "${STEP_ORDER[@]}"; do
      is_selected "$s" && "${STEP_FN[$s]}"
    done
    ;;
  unlink)
    info "Removing symlinks"
    for i in "${!SRCS[@]}"; do unlink_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    warn "Note: systemd units are not deactivated - do it manually if needed via 'systemctl [--user] disable …'."
    ;;
  status)
    info "Status (${#SRCS[@]} entries)"
    for i in "${!SRCS[@]}"; do status_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    ;;
esac

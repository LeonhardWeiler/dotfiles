#!/usr/bin/env bash
# Symlink-Manager für diese Dotfiles — ohne externe Abhängigkeiten.
# Liest die Mapping-Datei `links.conf` (Quelle → Ziel) und legt die Symlinks an,
# entfernt sie wieder oder zeigt ihren Ist-Zustand.
#
# Nutzung:
#   ./install [link]          Symlinks anlegen/auffrischen (Default)
#   ./install unlink          von uns verwaltete Symlinks entfernen
#   ./install status          Ist-Zustand aller Einträge zeigen
#   ./install clean           von --force angelegte .bak-Sicherungen löschen
#
# Optionen:
#   -n, --dry-run             nur zeigen, was passieren würde — nichts ändern
#   -c, --config DATEI        andere Mapping-Datei (Default: links.conf)
#       --user-only           nur ~-Ziele bearbeiten (keine /etc-Ziele, kein sudo)
#       --no-units            systemd-Units nicht (re)aktivieren
#       --force               reale Dateien/Verzeichnisse am Ziel nach .bak
#                             sichern und durch den Symlink ersetzen
#   -h, --help                diese Hilfe
set -euo pipefail

BASEDIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG="links.conf"
CMD="link"
DRYRUN=0
USER_ONLY=0
NO_UNITS=0
FORCE=0

# systemd-Units, die nach dem Verlinken (self-healing) reaktiviert werden.
USER_UNITS=(battery-check.timer dotfiles-sync.service)
# Nur real existierende System-Units. pipewire/wireplumber sind User-Dienste
# (Paket-Presets, nicht getrackt) und swtpm ist socket-aktiviert — die haben
# keine enable-bare <name>.service.
SYSTEM_UNITS=(NetworkManager.service ly@tty2.service dnsmasq.service sshd.service
  libvirtd.service legion-conservation.service)

# ── Ausgabe-Helfer ───────────────────────────────────────────────────────────
if [ -t 1 ]; then C_OK=$'\e[32m'; C_WARN=$'\e[33m'; C_INFO=$'\e[36m'; C_RST=$'\e[0m'
else C_OK=; C_WARN=; C_INFO=; C_RST=; fi
ok()   { printf '  %s✓%s %s\n' "$C_OK"   "$C_RST" "$*"; }
warn() { printf '  %s!%s %s\n' "$C_WARN" "$C_RST" "$*" >&2; }
info() { printf '%s%s%s\n'     "$C_INFO" "$*" "$C_RST"; }

usage() { awk 'NR>1{ if ($0 !~ /^#/) exit; sub(/^# ?/,""); print }' "$0"; exit "${1:-0}"; }

# ── Argument-Parsing ─────────────────────────────────────────────────────────
while [ $# -gt 0 ]; do
  case "$1" in
    link|unlink|status|clean) CMD="$1" ;;
    -n|--dry-run)  DRYRUN=1 ;;
    --user-only)   USER_ONLY=1 ;;
    --no-units)    NO_UNITS=1 ;;
    --force)       FORCE=1 ;;
    -c|--config)   shift; CONFIG="${1:?--config braucht eine Datei}" ;;
    -h|--help)     usage 0 ;;
    *) warn "unbekanntes Argument: $1"; usage 1 ;;
  esac
  shift
done

[ -f "$BASEDIR/$CONFIG" ] || { warn "Mapping-Datei nicht gefunden: $CONFIG"; exit 1; }

# ── Pfad-Helfer ──────────────────────────────────────────────────────────────
# `~` → Home des Nutzers.
expand_target() {
  case "$1" in
    "~")    printf '%s\n' "$HOME" ;;
    "~/"*)  printf '%s\n' "$HOME/${1#\~/}" ;;
    *)      printf '%s\n' "$1" ;;
  esac
}
# Ziel außerhalb von $HOME → braucht root.
needs_root() { case "$1" in "$HOME"/*|"$HOME") return 1 ;; *) return 0 ;; esac; }

# `run <root?> cmd…` — führt ein Kommando (ggf. per sudo) aus, respektiert Dry-Run.
run() {
  local root="$1"; shift
  if [ "$DRYRUN" = 1 ]; then
    printf '    [dry] %s%s\n' "$([ "$root" = 1 ] && printf 'sudo ')" "$*"
    return 0
  fi
  if [ "$root" = 1 ]; then sudo "$@"; else "$@"; fi
}

# ── Aktionen pro Eintrag ─────────────────────────────────────────────────────
link_one() {
  local rel="$1" src="$BASEDIR/$1" target; target="$(expand_target "$2")"
  local root=0; needs_root "$target" && root=1
  { [ "$USER_ONLY" = 1 ] && [ "$root" = 1 ]; } && return 0
  if [ ! -e "$src" ]; then warn "Quelle fehlt, übersprungen: $rel"; return 0; fi
  if [ -e "$target" ] && [ ! -L "$target" ]; then
    if [ "$FORCE" = 1 ]; then
      local bak="$target.bak"
      if [ -e "$bak" ]; then bak="$target.bak.$(date +%s)"; fi
      run "$root" mv "$target" "$bak"; ok "gesichert: $target → $bak"
    else
      warn "reale Datei/Verzeichnis, übersprungen (mit --force sichern & ersetzen): $target"; return 0
    fi
  fi
  local parent; parent="$(dirname "$target")"
  # Ein toter (kaputter) Symlink als Eltern-Pfad — z. B. Rest aus einem alten
  # Setup — bringt sonst `mkdir -p` mit „File exists" zu Fall und beendet unter
  # `set -e` den ganzen Lauf. Ein toter Symlink hat keinen Inhalt → gefahrlos
  # entfernen (nur echte, ins Leere zeigende Symlinks; reale Dateien/Ordner
  # bleiben unberührt).
  if [ -L "$parent" ] && [ ! -e "$parent" ]; then run "$root" rm -f "$parent"; fi
  if [ ! -d "$parent" ]; then
    run "$root" mkdir -p "$parent" \
      || { warn "Eltern-Pfad nicht anlegbar, übersprungen: $parent"; return 0; }
  fi
  run "$root" ln -sfn "$src" "$target"
  ok "$2 → $rel"
}

unlink_one() {
  local rel="$1" src="$BASEDIR/$1" target; target="$(expand_target "$2")"
  local root=0; needs_root "$target" && root=1
  { [ "$USER_ONLY" = 1 ] && [ "$root" = 1 ]; } && return 0
  if [ -L "$target" ]; then
    if [ "$(readlink "$target")" = "$src" ]; then
      run "$root" rm "$target"; ok "entfernt: $2"
    else
      warn "Symlink zeigt woanders hin (behalten): $target"
    fi
  elif [ -e "$target" ]; then
    warn "kein Symlink (behalten): $target"
  fi
}

status_one() {
  local rel="$1" src="$BASEDIR/$1" target; target="$(expand_target "$2")"
  local state
  if [ -L "$target" ]; then
    if [ "$(readlink "$target")" = "$src" ]; then state="${C_OK}ok${C_RST}"
    else state="${C_WARN}link→$(readlink "$target")${C_RST}"; fi
  elif [ -e "$target" ]; then state="${C_WARN}echte Datei${C_RST}"
  else state="fehlt"; fi
  printf '  %-46s %s\n' "$2" "$state"
}

clean_one() {
  local target; target="$(expand_target "$2")"
  local root=0; needs_root "$target" && root=1
  { [ "$USER_ONLY" = 1 ] && [ "$root" = 1 ]; } && return 0
  local b
  shopt -s nullglob
  for b in "$target.bak" "$target".bak.[0-9]*; do
    { [ -e "$b" ] || [ -L "$b" ]; } || continue
    run "$root" rm -rf "$b"; ok "gelöscht: $b"
  done
  shopt -u nullglob
}

reactivate_units() {
  [ "$NO_UNITS" = 1 ] && return 0
  # Bewusst `enable`, nicht `reenable`: unsere Unit-Dateien sind Symlinks
  # (linked units); `reenable` würde beim internen `disable` genau diesen
  # Unit-Symlink löschen. `enable` ist idempotent und legt nur den fehlenden
  # Enablement-Link (…​.wants/) an — überlebt auch den Repo-Umzug, weil der
  # Unit-Symlink am Standardpfad liegt.
  info "systemd User-Units aktivieren"
  run 0 systemctl --user daemon-reload || warn "daemon-reload fehlgeschlagen"
  for u in "${USER_UNITS[@]}"; do
    if [ "$DRYRUN" = 1 ]; then run 0 systemctl --user enable "$u"
    else run 0 systemctl --user enable "$u" >/dev/null 2>&1 || warn "User-Unit nicht aktiviert: $u"; fi
  done
  [ "$USER_ONLY" = 1 ] && return 0
  info "systemd System-Units aktivieren (sudo)"
  for u in "${SYSTEM_UNITS[@]}"; do
    if [ "$DRYRUN" = 1 ]; then run 1 systemctl enable "$u"
    else run 1 systemctl enable "$u" >/dev/null 2>&1 || warn "System-Unit nicht aktiviert: $u"; fi
  done
}

# ── Mapping-Datei einlesen (erst komplett, dann iterieren — sonst kollidiert
#    ein sudo-Passwort-Prompt mit dem stdin der Lese-Schleife) ────────────────
SRCS=(); TGTS=()
while IFS= read -r line || [ -n "$line" ]; do
  line="${line%%#*}"                 # Kommentar ab # abschneiden
  read -r s t _ <<<"$line" || true   # erste zwei Felder (trimmt/kollabiert Leerraum)
  [ -z "${s:-}" ] && continue
  if [ -z "${t:-}" ]; then warn "ungültige Zeile (kein Ziel): $line"; continue; fi
  # Glob in der Quelle (z. B. `config/usrbin/*`): jeden Treffer einzeln in das
  # Ziel-Verzeichnis verlinken (Ziel/<basename>). So bleibt das Ziel-Verzeichnis
  # real und fremde Einträge darin bleiben unangetastet.
  if [[ "$s" == *"*"* ]]; then
    matched=0
    shopt -s nullglob
    for m in "$BASEDIR"/$s; do
      SRCS+=("${m#"$BASEDIR"/}"); TGTS+=("${t%/}/${m##*/}"); matched=1
    done
    shopt -u nullglob
    [ "$matched" = 0 ] && warn "Glob ohne Treffer: $s"
    continue
  fi
  SRCS+=("$s"); TGTS+=("$t")
done < "$BASEDIR/$CONFIG"

[ "${#SRCS[@]}" -gt 0 ] || { warn "keine Einträge in $CONFIG"; exit 1; }

# ── Ausführung ───────────────────────────────────────────────────────────────
[ "$DRYRUN" = 1 ] && info "— Dry-Run: es wird nichts verändert —"
case "$CMD" in
  link)
    info "Symlinks anlegen (${#SRCS[@]} Einträge)"
    for i in "${!SRCS[@]}"; do link_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    reactivate_units
    ;;
  unlink)
    info "Symlinks entfernen"
    for i in "${!SRCS[@]}"; do unlink_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    warn "Hinweis: systemd-Units werden nicht deaktiviert — bei Bedarf manuell 'systemctl [--user] disable …'."
    ;;
  status)
    info "Status (${#SRCS[@]} Einträge)"
    for i in "${!SRCS[@]}"; do status_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    ;;
  clean)
    info "Backups (.bak) der verwalteten Ziele löschen"
    for i in "${!SRCS[@]}"; do clean_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    ;;
esac

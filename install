#!/usr/bin/env bash
# Symlink-Manager für diese Dotfiles — ohne externe Abhängigkeiten.
# Liest die Mapping-Datei `links.conf` (Quelle → Ziel) und legt die Symlinks an,
# entfernt sie wieder oder zeigt ihren Ist-Zustand.
#
# Nutzung:
#   ./install [link]          Symlinks anlegen/auffrischen (Default, Alltag)
#   ./install setup           Neue Maschine, EIN Kommando: optionale Schritte
#                             (Menü) → Configs verlinken (--force) → Units
#                             aktivieren → manuelle Rest-Checkliste
#   ./install unlink          von uns verwaltete Symlinks entfernen
#   ./install status          Ist-Zustand aller Einträge zeigen
#   ./install clean           von --force angelegte .bak-Sicherungen löschen
#
# Optionale Setup-Schritte (im `setup`-Menü wählbar, einzeln per Flag
# automatisierbar — z. B. `./install --groups` oder `./install setup --timezone Europe/Vienna`):
#   --programs                Pakete aus setup/programs.txt installieren (yay)
#   --remove-programs         explizit installierte Pakete entfernen, die NICHT
#                             in programs.txt stehen (Manifest-Prune, mit Rückfrage)
#   --systemd                 systemd-Units aktivieren (USER_UNITS + SYSTEM_UNITS)
#   --remove-systemd          dieselben Units wieder deaktivieren (mit Rückfrage)
#   --groups                  Benutzer zu den benötigten Gruppen hinzufügen (usermod -aG)
#   --timezone ZONE           Zeitzone setzen (z. B. --timezone Europe/Vienna);
#                             ohne ZONE fragt das Menü interaktiv nach
#   --locale                  Locales aus /etc/locale.gen generieren (locale-gen)
#   --ly-dropin               ly@tty2-Drop-ins als reale Kopien nach /etc deployen
#   --sudoers                 passwortloses sudo für die wheel-Gruppe einrichten
#                             (/etc/sudoers.d/, per visudo geprüft)
#
# Optionen:
#   -n, --dry-run             nur zeigen, was passieren würde — nichts ändern
#   -c, --config DATEI        andere Mapping-Datei (Default: setup/links.conf)
#       --user-only           nur ~-Ziele bearbeiten (keine /etc-Ziele, kein sudo)
#       --no-units            systemd-Units nicht (re)aktivieren
#       --force               reale Dateien/Verzeichnisse am Ziel nach .bak
#                             sichern und durch den Symlink ersetzen
#   -h, --help                diese Hilfe
set -euo pipefail

BASEDIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG="setup/links.conf"
CMD="link"
EXPLICIT_CMD=0       # wurde ein Subkommando explizit getippt?
DRYRUN=0
USER_ONLY=0
NO_UNITS=0
FORCE=0
SKIPPED_REAL=0       # Anzahl übersprungener realer Ziele (ohne --force) — für den Schlusshinweis
FLAG_STEPS_GIVEN=0   # wurde mindestens ein --<schritt>-Flag übergeben?
TIMEZONE=""          # optionaler --timezone-Wert (Region/Stadt)

# systemd-Units, die nach dem Verlinken (self-healing) reaktiviert werden.
USER_UNITS=(battery-check.timer dotfiles-sync.service)
# Nur real existierende System-Units. pipewire/wireplumber sind User-Dienste
# (Paket-Presets, nicht getrackt) und swtpm ist socket-aktiviert — die haben
# keine enable-bare <name>.service. iptables lädt die (Default-)Regeln aus
# /etc/iptables/; fstrim.timer macht periodisches SSD-TRIM; timesyncd = NTP;
# power-profiles-daemon = Energieprofile (Notebook).
SYSTEM_UNITS=(NetworkManager.service ly@tty2.service dnsmasq.service sshd.service
  libvirtd.service legion-conservation.service iptables.service
  power-profiles-daemon.service systemd-timesyncd.service fstrim.timer)

# ── Ausgabe-Helfer ───────────────────────────────────────────────────────────
if [ -t 1 ]; then C_OK=$'\e[32m'; C_WARN=$'\e[33m'; C_INFO=$'\e[36m'; C_RST=$'\e[0m'
else C_OK=; C_WARN=; C_INFO=; C_RST=; fi
ok()   { printf '  %s✓%s %s\n' "$C_OK"   "$C_RST" "$*"; }
warn() { printf '  %s!%s %s\n' "$C_WARN" "$C_RST" "$*" >&2; }
info() { printf '%s%s%s\n'     "$C_INFO" "$*" "$C_RST"; }

usage() { awk 'NR>1{ if ($0 !~ /^#/) exit; sub(/^# ?/,""); print }' "$0"; exit "${1:-0}"; }

# ── Optionale Setup-Schritte (Registry) ──────────────────────────────────────
# Jeder Schritt hat eine do_<name>-Funktion, ein Flag `--<name>` und eine
# Menü-Zeile im `setup`. Neue Schritte werden weiter unten per register_step
# eingetragen. SELECTED hält die aktuell ausgewählten Schritte.
STEP_ORDER=()
declare -A STEP_DESC STEP_FN SELECTED
# Im `setup` vorausgewählte Schritte (Menü-Enter / kein TTY = diese Defaults).
DEFAULT_STEPS=(programs systemd locale)
register_step() { STEP_ORDER+=("$1"); STEP_FN[$1]="$2"; STEP_DESC[$1]="$3"; }
is_selected()   { [ -n "${SELECTED[$1]:-}" ]; }

# Interaktive Ja/Nein-Rückfrage. Ohne TTY (skriptbar) immer „nein".
confirm() {
  local reply
  [ -t 0 ] || return 1
  printf '%s [y/N] ' "$1" >&2
  read -r reply || return 1
  case "$reply" in [yYjJ]*) return 0 ;; *) return 1 ;; esac
}

# ── Argument-Parsing ─────────────────────────────────────────────────────────
while [ $# -gt 0 ]; do
  case "$1" in
    link|setup|unlink|status|clean) CMD="$1"; EXPLICIT_CMD=1 ;;
    -n|--dry-run)  DRYRUN=1 ;;
    --user-only)   USER_ONLY=1 ;;
    --no-units)    NO_UNITS=1 ;;
    --force)       FORCE=1 ;;
    -c|--config)   shift; CONFIG="${1:?--config braucht eine Datei}" ;;
    -h|--help)     usage 0 ;;
    # ── Schritt-Flags (siehe Registry) ──────────────────────────────────────
    --programs)         SELECTED[programs]=1;        FLAG_STEPS_GIVEN=1 ;;
    --remove-programs)  SELECTED[remove-programs]=1; FLAG_STEPS_GIVEN=1 ;;
    --systemd)          SELECTED[systemd]=1;         FLAG_STEPS_GIVEN=1 ;;
    --remove-systemd)   SELECTED[remove-systemd]=1;  FLAG_STEPS_GIVEN=1 ;;
    --groups)           SELECTED[groups]=1;          FLAG_STEPS_GIVEN=1 ;;
    --timezone)         shift; TIMEZONE="${1:?--timezone braucht eine Zone (Region/Stadt)}"
                        SELECTED[timezone]=1;        FLAG_STEPS_GIVEN=1 ;;
    --locale)           SELECTED[locale]=1;          FLAG_STEPS_GIVEN=1 ;;
    --ly-dropin)        SELECTED[ly-dropin]=1;       FLAG_STEPS_GIVEN=1 ;;
    --sudoers)          SELECTED[sudoers]=1;         FLAG_STEPS_GIVEN=1 ;;
    *) warn "unbekanntes Argument: $1"; usage 1 ;;
  esac
  shift
done

# Ohne explizites Subkommando, aber mit Schritt-Flags → nur diese Schritte
# ausführen (skriptbar, kein Verlinken, kein Menü).
if [ "$EXPLICIT_CMD" = 0 ] && [ "$FLAG_STEPS_GIVEN" = 1 ]; then CMD="run-steps"; fi

[ -f "$BASEDIR/$CONFIG" ] || { warn "Mapping-Datei nicht gefunden: $CONFIG"; exit 1; }

# ── Pfad-Helfer ──────────────────────────────────────────────────────────────
# `~` → Home des Nutzers.
expand_target() {
  case "$1" in
    "~")    printf '%s\n' "$HOME" ;;
    "~/"*)  printf '%s\n' "$HOME/${1#\~/}" ;;
    *)      printf '%s\n' "$1" ;;
  esac
}
# Ziel außerhalb von $HOME → braucht root.
needs_root() { case "$1" in "$HOME"/*|"$HOME") return 1 ;; *) return 0 ;; esac; }

# `run <root?> cmd…` — führt ein Kommando (ggf. per sudo) aus, respektiert Dry-Run.
run() {
  local root="$1"; shift
  if [ "$DRYRUN" = 1 ]; then
    printf '    [dry] %s%s\n' "$([ "$root" = 1 ] && printf 'sudo ')" "$*"
    return 0
  fi
  if [ "$root" = 1 ]; then sudo "$@"; else "$@"; fi
}

# ── Aktionen pro Eintrag ─────────────────────────────────────────────────────
link_one() {
  local rel="$1" src="$BASEDIR/$1" target; target="$(expand_target "$2")"
  local root=0; needs_root "$target" && root=1
  { [ "$USER_ONLY" = 1 ] && [ "$root" = 1 ]; } && return 0
  if [ ! -e "$src" ]; then warn "Quelle fehlt, übersprungen: $rel"; return 0; fi
  if [ -e "$target" ] && [ ! -L "$target" ]; then
    if [ "$FORCE" = 1 ]; then
      local bak="$target.bak"
      if [ -e "$bak" ]; then bak="$target.bak.$(date +%s)"; fi
      run "$root" mv "$target" "$bak"; ok "gesichert: $target → $bak"
    else
      warn "reale Datei/Verzeichnis, übersprungen (mit --force sichern & ersetzen): $target"
      SKIPPED_REAL=$((SKIPPED_REAL + 1)); return 0
    fi
  fi
  local parent; parent="$(dirname "$target")"
  # Ein toter (kaputter) Symlink als Eltern-Pfad — z. B. Rest aus einem alten
  # Setup — bringt sonst `mkdir -p` mit „File exists" zu Fall und beendet unter
  # `set -e` den ganzen Lauf. Ein toter Symlink hat keinen Inhalt → gefahrlos
  # entfernen (nur echte, ins Leere zeigende Symlinks; reale Dateien/Ordner
  # bleiben unberührt).
  if [ -L "$parent" ] && [ ! -e "$parent" ]; then run "$root" rm -f "$parent"; fi
  if [ ! -d "$parent" ]; then
    run "$root" mkdir -p "$parent" \
      || { warn "Eltern-Pfad nicht anlegbar, übersprungen: $parent"; return 0; }
  fi
  run "$root" ln -sfn "$src" "$target"
  ok "$2 → $rel"
}

unlink_one() {
  local rel="$1" src="$BASEDIR/$1" target; target="$(expand_target "$2")"
  local root=0; needs_root "$target" && root=1
  { [ "$USER_ONLY" = 1 ] && [ "$root" = 1 ]; } && return 0
  if [ -L "$target" ]; then
    if [ "$(readlink "$target")" = "$src" ]; then
      run "$root" rm "$target"; ok "entfernt: $2"
    else
      warn "Symlink zeigt woanders hin (behalten): $target"
    fi
  elif [ -e "$target" ]; then
    warn "kein Symlink (behalten): $target"
  fi
}

status_one() {
  local rel="$1" src="$BASEDIR/$1" target; target="$(expand_target "$2")"
  local state
  if [ -L "$target" ]; then
    if [ "$(readlink "$target")" = "$src" ]; then state="${C_OK}ok${C_RST}"
    else state="${C_WARN}link→$(readlink "$target")${C_RST}"; fi
  elif [ -e "$target" ]; then state="${C_WARN}echte Datei${C_RST}"
  else state="fehlt"; fi
  printf '  %-46s %s\n' "$2" "$state"
}

clean_one() {
  local target; target="$(expand_target "$2")"
  local root=0; needs_root "$target" && root=1
  { [ "$USER_ONLY" = 1 ] && [ "$root" = 1 ]; } && return 0
  local b
  shopt -s nullglob
  for b in "$target.bak" "$target".bak.[0-9]*; do
    { [ -e "$b" ] || [ -L "$b" ]; } || continue
    run "$root" rm -rf "$b"; ok "gelöscht: $b"
  done
  shopt -u nullglob
}

# ── Optionale Schritt-Funktionen ─────────────────────────────────────────────
# Pakete aus setup/programs.txt installieren. Delegiert an setup/install-programs
# (bootstrappt yay aus dem AUR, falls nötig; überspringt bereits installierte
# Pakete). Läuft VOR dem Verlinken, damit danach reaktivierte Units existieren.
do_programs_install() {
  local script="$BASEDIR/setup/install-programs"
  [ -x "$script" ] || { warn "setup/install-programs fehlt/nicht ausführbar: $script"; return 0; }
  info "Pakete aus setup/programs.txt installieren (yay)"
  if [ "$DRYRUN" = 1 ]; then printf '    [dry] %s\n' "$script"; return 0; fi
  "$script" || warn "Paket-Installation nicht (vollständig) erfolgreich"
}
register_step programs do_programs_install "Pakete aus programs.txt installieren"

# Explizit installierte Pakete entfernen, die NICHT im Manifest (programs.txt)
# stehen — zieht das System auf die getrackte Paketliste. Bewusst mit Rückfrage
# und Default „nein" (aggressive Operation); yay -Rns räumt auch Abhängigkeiten
# und Config-Reste weg.
do_programs_remove() {
  command -v pacman >/dev/null 2>&1 || { warn "pacman fehlt — Paket-Entfernung übersprungen"; return 0; }
  local manifest="$BASEDIR/setup/programs.txt"
  [ -f "$manifest" ] || { warn "programs.txt fehlt — nichts zu entfernen"; return 0; }
  info "Nicht getrackte Pakete ermitteln (explizit installiert, aber nicht in programs.txt)"
  local extras
  extras="$(comm -23 <(pacman -Qqe | sort -u) <(awk 'NF{print $1}' "$manifest" | sort -u))"
  if [ -z "$extras" ]; then ok "keine ungetrackten Pakete — nichts zu entfernen"; return 0; fi
  printf '  Zu entfernen:\n'; printf '    %s\n' $extras
  if [ "$DRYRUN" = 1 ]; then printf '    [dry] sudo pacman -Rns %s\n' "$extras"; return 0; fi
  if confirm "  Diese Pakete wirklich entfernen (yay -Rns)?"; then
    # shellcheck disable=SC2086
    run 1 pacman -Rns $extras || warn "Paket-Entfernung nicht (vollständig) erfolgreich"
  else
    info "Paket-Entfernung übersprungen"
  fi
}
register_step remove-programs do_programs_remove "Nicht getrackte Pakete entfernen (Prune)"

# Schlusshinweis nach dem Verlinken: übersprungene reale Ziele prominent melden
# und den Nutzer daran erinnern, die frisch verlinkte Shell-Config anzuwenden.
# (Ein Skript kann die interaktive Eltern-Shell nicht selbst neu laden — daher
# der explizite Hinweis statt eines wirkungslosen `source` im Skript.)
next_steps() {
  if [ "$SKIPPED_REAL" -gt 0 ]; then
    warn "$SKIPPED_REAL reale(s) Ziel(e) übersprungen — mit './install --force' nach .bak sichern und ersetzen."
  fi
  [ "$DRYRUN" = 1 ] && return 0
  info "Nächste Schritte"
  printf '  • %ssource ~/.bashrc%s  — Shell-Config sofort anwenden (lädt auch ~/.nix-profile via nix.sh)\n' "$C_OK" "$C_RST"
  printf '  • für die .bash_profile-Env (GTK_THEME, QT_QPA_PLATFORMTHEME, XDG_*) einmal neu einloggen\n'
}

# Die frisch verlinkten Locales (/etc/locale.gen) generieren (idempotent).
do_locale() {
  if [ "$USER_ONLY" = 1 ]; then warn "--user-only: locale-gen übersprungen"; return 0; fi
  info "Locales generieren (locale-gen)"
  run 1 locale-gen || warn "locale-gen fehlgeschlagen"
}
register_step locale do_locale "Locales generieren (locale-gen)"

# Interaktives Menü: optionale Schritte auswählen. Bei per Flag vorgewählten
# Schritten (FLAG_STEPS_GIVEN) übernimmt es diese unverändert; ohne TTY greifen
# die DEFAULT_STEPS.
choose_steps() {
  [ "$FLAG_STEPS_GIVEN" = 1 ] && return 0
  if [ ! -t 0 ]; then for s in "${DEFAULT_STEPS[@]}"; do SELECTED[$s]=1; done; return 0; fi
  info "Optionale Schritte auswählen (Nummern per Leerzeichen; Enter = Defaults)"
  local i=1 idx=() def
  for s in "${STEP_ORDER[@]}"; do
    def=""; for d in "${DEFAULT_STEPS[@]}"; do [ "$d" = "$s" ] && def=" (default)"; done
    printf '  [%d] %s%s\n' "$i" "${STEP_DESC[$s]}" "$def"; idx[$i]="$s"; i=$((i+1))
  done
  printf '> '; local line n; read -r line || line=""
  if [ -z "$line" ]; then for s in "${DEFAULT_STEPS[@]}"; do SELECTED[$s]=1; done; return 0; fi
  for n in $line; do [ -n "${idx[$n]:-}" ] && SELECTED[${idx[$n]}]=1; done
}

# Verlinken-Kern (nur Symlinks). Paket-/Unit-Schritte laufen separat.
do_symlinks() {
  info "Symlinks anlegen (${#SRCS[@]} Einträge)"
  for i in "${!SRCS[@]}"; do link_one "${SRCS[$i]}" "${TGTS[$i]}"; done
}

reactivate_units() {
  [ "$NO_UNITS" = 1 ] && return 0
  # Bewusst `enable`, nicht `reenable`: unsere Unit-Dateien sind Symlinks
  # (linked units); `reenable` würde beim internen `disable` genau diesen
  # Unit-Symlink löschen. `enable` ist idempotent und legt nur den fehlenden
  # Enablement-Link (…​.wants/) an — überlebt auch den Repo-Umzug, weil der
  # Unit-Symlink am Standardpfad liegt.
  info "systemd User-Units aktivieren"
  run 0 systemctl --user daemon-reload || warn "daemon-reload fehlgeschlagen"
  for u in "${USER_UNITS[@]}"; do
    if [ "$DRYRUN" = 1 ]; then run 0 systemctl --user enable "$u"
    else run 0 systemctl --user enable "$u" >/dev/null 2>&1 || warn "User-Unit nicht aktiviert: $u"; fi
  done
  [ "$USER_ONLY" = 1 ] && return 0
  info "systemd System-Units aktivieren (sudo)"
  for u in "${SYSTEM_UNITS[@]}"; do
    if [ "$DRYRUN" = 1 ]; then run 1 systemctl enable "$u"
    else run 1 systemctl enable "$u" >/dev/null 2>&1 || warn "System-Unit nicht aktiviert: $u"; fi
  done
}
register_step systemd reactivate_units "systemd-Units aktivieren (enable)"

# Gegenstück zu reactivate_units: dieselben Units wieder deaktivieren. Hinweis:
# unsere Unit-Dateien sind linked units (Symlinks am Standardpfad) — `disable`
# entfernt bei solchen Units auch diesen Symlink, die Unit ist danach ganz weg
# (Neu-Verlinken via `./install` legt sie wieder an). Daher mit Rückfrage.
do_systemd_disable() {
  [ "$DRYRUN" = 0 ] && ! confirm "  systemd-Units wirklich deaktivieren?" && { info "übersprungen"; return 0; }
  info "systemd User-Units deaktivieren"
  for u in "${USER_UNITS[@]}"; do
    run 0 systemctl --user disable "$u" >/dev/null 2>&1 || warn "User-Unit nicht deaktiviert: $u"
  done
  [ "$USER_ONLY" = 1 ] && return 0
  info "systemd System-Units deaktivieren (sudo)"
  for u in "${SYSTEM_UNITS[@]}"; do
    run 1 systemctl disable "$u" >/dev/null 2>&1 || warn "System-Unit nicht deaktiviert: $u"
  done
}
register_step remove-systemd do_systemd_disable "systemd-Units deaktivieren (disable)"

# Benutzer zu den Gruppen der getrackten Tools hinzufügen. `GROUPS` ist in Bash
# reserviert (aktuelle GIDs) — daher GROUP_LIST. docker/wireshark bewusst nicht
# dabei (nur nötig, wenn man diese Pakete auch installiert).
GROUP_LIST="wheel,input,kvm,libvirt,uucp,disk,lock"
do_groups() {
  local user="${SUDO_USER:-${USER:-}}"
  [ -n "$user" ] || { warn "kein Benutzer ermittelbar — Gruppen übersprungen"; return 0; }
  info "Benutzer '$user' zu Gruppen hinzufügen: $GROUP_LIST"
  run 1 usermod -aG "$GROUP_LIST" "$user" || warn "usermod fehlgeschlagen"
  info "(Gruppenänderung wirkt erst nach erneutem Login)"
}
register_step groups do_groups "Benutzer zu Gruppen hinzufügen ($GROUP_LIST)"

# Zeitzone per Symlink /etc/localtime → /usr/share/zoneinfo/<Zone> setzen. Zone
# aus --timezone oder (im Menü) interaktiv erfragt.
do_timezone() {
  local tz="$TIMEZONE"
  if [ -z "$tz" ] && [ -t 0 ]; then
    printf '  Zeitzone (Region/Stadt, z. B. Europe/Vienna): ' >&2; read -r tz || tz=""
  fi
  [ -n "$tz" ] || { warn "keine Zeitzone angegeben — übersprungen"; return 0; }
  if [ ! -e "/usr/share/zoneinfo/$tz" ]; then warn "unbekannte Zeitzone: $tz — übersprungen"; return 0; fi
  info "Zeitzone setzen: $tz"
  run 1 ln -sf "/usr/share/zoneinfo/$tz" /etc/localtime || warn "Zeitzone setzen fehlgeschlagen"
}
register_step timezone do_timezone "Zeitzone setzen (/etc/localtime)"

# ly@tty2-Drop-ins als REALE Kopien auf die Root-Partition legen (nicht per
# links.conf symlinken): systemd liest Unit-Drop-ins früh beim Manager-Start,
# wenn ein /home-Symlink noch ein toter Link wäre. Danach daemon-reload.
LY_DROPIN_DIR="/etc/systemd/system/ly@tty2.service.d"
do_ly_dropin() {
  local src="$BASEDIR/config/systemd-system/ly@tty2.service.d"
  [ -d "$src" ] || { warn "ly@tty2-Drop-in-Quelle fehlt: $src"; return 0; }
  info "ly@tty2-Drop-ins nach $LY_DROPIN_DIR kopieren"
  run 1 install -d -m755 "$LY_DROPIN_DIR" || { warn "Verzeichnis nicht anlegbar"; return 0; }
  run 1 install -m644 "$src"/wait-home.conf "$src"/keymap.conf "$LY_DROPIN_DIR"/ \
    || warn "Drop-in-Kopie fehlgeschlagen"
  run 1 systemctl daemon-reload || warn "daemon-reload fehlgeschlagen"
}
register_step ly-dropin do_ly_dropin "ly@tty2-Drop-ins deployen (reale Kopien)"

# Passwortloses sudo für die wheel-Gruppe — bewusste Komfort-Entscheidung dieses
# Setups. Als Drop-in in /etc/sudoers.d/ (0440), vorher mit `visudo -c` auf einer
# Temp-Datei geprüft, damit keine kaputte sudoers-Syntax das System aussperrt.
do_sudoers() {
  local file="/etc/sudoers.d/10-wheel-nopasswd"
  local rule="%wheel ALL=(ALL:ALL) NOPASSWD: ALL"
  info "Passwortloses sudo für wheel einrichten: $file"
  if [ "$DRYRUN" = 1 ]; then
    printf "    [dry] printf '%s' | visudo -c && sudo install -m0440 → %s\n" "$rule" "$file"; return 0
  fi
  local tmp; tmp="$(mktemp)"; printf '%s\n' "$rule" > "$tmp"
  if ! visudo -cf "$tmp" >/dev/null 2>&1; then
    warn "sudoers-Syntax ungültig — übersprungen"; rm -f "$tmp"; return 0
  fi
  run 1 install -m0440 -o root -g root "$tmp" "$file" || warn "sudoers-Datei nicht installiert"
  rm -f "$tmp"
}
register_step sudoers do_sudoers "Passwortloses sudo für wheel (sudoers.d)"

# ── Mapping-Datei einlesen (erst komplett, dann iterieren — sonst kollidiert
#    ein sudo-Passwort-Prompt mit dem stdin der Lese-Schleife) ────────────────
SRCS=(); TGTS=()
while IFS= read -r line || [ -n "$line" ]; do
  line="${line%%#*}"                 # Kommentar ab # abschneiden
  read -r s t _ <<<"$line" || true   # erste zwei Felder (trimmt/kollabiert Leerraum)
  [ -z "${s:-}" ] && continue
  if [ -z "${t:-}" ]; then warn "ungültige Zeile (kein Ziel): $line"; continue; fi
  # Glob in der Quelle (z. B. `config/usrbin/*`): jeden Treffer einzeln in das
  # Ziel-Verzeichnis verlinken (Ziel/<basename>). So bleibt das Ziel-Verzeichnis
  # real und fremde Einträge darin bleiben unangetastet.
  if [[ "$s" == *"*"* ]]; then
    matched=0
    shopt -s nullglob
    for m in "$BASEDIR"/$s; do
      SRCS+=("${m#"$BASEDIR"/}"); TGTS+=("${t%/}/${m##*/}"); matched=1
    done
    shopt -u nullglob
    [ "$matched" = 0 ] && warn "Glob ohne Treffer: $s"
    continue
  fi
  SRCS+=("$s"); TGTS+=("$t")
done < "$BASEDIR/$CONFIG"

[ "${#SRCS[@]}" -gt 0 ] || { warn "keine Einträge in $CONFIG"; exit 1; }

# ── Ausführung ───────────────────────────────────────────────────────────────
[ "$DRYRUN" = 1 ] && info "— Dry-Run: es wird nichts verändert —"
case "$CMD" in
  link)
    do_symlinks
    reactivate_units
    next_steps
    ;;
  setup)
    # Ein-Kommando-Bootstrap für eine frische Maschine.
    FORCE=1
    info "Setup: optionale Schritte → verlinken (--force) → Units → Rest-Checkliste"
    choose_steps
    is_selected programs && do_programs_install
    do_symlinks
    is_selected systemd && reactivate_units
    is_selected remove-systemd && do_systemd_disable
    is_selected groups && do_groups
    is_selected timezone && do_timezone
    is_selected ly-dropin && do_ly_dropin
    is_selected sudoers && do_sudoers
    is_selected locale && do_locale
    is_selected remove-programs && do_programs_remove
    next_steps
    ;;
  run-steps)
    # Nur die per Flag gewählten optionalen Schritte (skriptbar), in
    # kanonischer Reihenfolge (STEP_ORDER).
    for s in "${STEP_ORDER[@]}"; do
      is_selected "$s" && "${STEP_FN[$s]}"
    done
    ;;
  unlink)
    info "Symlinks entfernen"
    for i in "${!SRCS[@]}"; do unlink_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    warn "Hinweis: systemd-Units werden nicht deaktiviert — bei Bedarf manuell 'systemctl [--user] disable …'."
    ;;
  status)
    info "Status (${#SRCS[@]} Einträge)"
    for i in "${!SRCS[@]}"; do status_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    ;;
  clean)
    info "Backups (.bak) der verwalteten Ziele löschen"
    for i in "${!SRCS[@]}"; do clean_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    ;;
esac

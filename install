#!/usr/bin/env bash
# Symlink manager for these dotfiles - no external dependencies.
# Reads the mapping file `links.conf` (source -> target) and creates the
# symlinks, removes them again, or shows their current state.
#
# Usage:
#   ./install [link]          create/refresh symlinks (default, everyday)
#   ./install setup           fresh machine, ONE command: optional steps (menu)
#                             -> link configs (--force) -> activate units
#   ./install unlink          remove the symlinks we manage
#   ./install status          show the current state of every entry
#   ./install clean           delete the .bak backups created by --force
#
# Optional setup steps (selectable in the `setup` menu, runnable individually via
# a flag for automation - e.g. `./install --groups` or
# `./install setup --timezone Europe/Vienna`):
#   --programs                install packages from setup/programs.txt (yay)
#   --remove-programs         remove explicitly installed packages that are NOT
#                             in programs.txt (manifest prune, asks first)
#   --systemd                 activate systemd units (USER_UNITS + SYSTEM_UNITS)
#   --remove-systemd          deactivate those same units (asks first)
#   --groups                  add the user to the required groups (usermod -aG)
#   --timezone ZONE           set the timezone (e.g. --timezone Europe/Vienna);
#                             without ZONE the menu asks interactively
#   --locale                  generate the locales from /etc/locale.gen (locale-gen)
#   --ly-dropin               deploy the ly@tty2 drop-ins as real copies to /etc
#   --sudoers                 set up passwordless sudo for the wheel group
#                             (/etc/sudoers.d/, validated with visudo)
#   --initramfs               rebuild the initramfs (mkinitcpio -P)
#   --fonts                   install the font packages and refresh the font cache
#   --scrub                   replace personal data (git identity/signing, restic
#                             backup host, the WLR_DRM_DEVICES GPU pin) with
#                             generic placeholders in the working copy - for
#                             non-owner clones. `setup` asks interactively (owner
#                             prompt); non-interactively it only scrubs with this
#                             flag.
#   --no-scrub                force-keep the personal data (skip the owner prompt)
#
# Options:
#   -n, --dry-run             only show what would happen - change nothing
#   -c, --config FILE         other mapping file (default: setup/links.conf)
#       --user-only           only ~ targets (no /etc targets, no sudo)
#       --no-units            do not (re)activate the systemd units
#       --force               back up real files/dirs at the target to .bak and
#                             replace them with the symlink
#   -h, --help                this help
set -euo pipefail

BASEDIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG="setup/links.conf"
CMD="link"
EXPLICIT_CMD=0       # was a subcommand typed explicitly?
DRYRUN=0
USER_ONLY=0
NO_UNITS=0
FORCE=0
SKIPPED_REAL=0       # number of skipped real targets (without --force) - for the closing hint
FLAG_STEPS_GIVEN=0   # was at least one --<step> flag passed?
TIMEZONE=""          # optional --timezone value (Region/City)
SCRUB_CHOICE=""      # personal-data scrub: "" = ask on a TTY / keep otherwise,
                     # 1 = --scrub (force), 0 = --no-scrub (force off)

# systemd units reactivated after linking (self-healing).
USER_UNITS=(battery-check.timer dotfiles-sync.service)
# Only system units that really exist. pipewire/wireplumber are user services
# (package presets, not tracked) and swtpm is socket-activated - those have no
# enable-able bare <name>.service. iptables loads the (default) rules from
# /etc/iptables/; fstrim.timer does periodic SSD TRIM; timesyncd = NTP;
# power-profiles-daemon = power profiles (laptop).
SYSTEM_UNITS=(NetworkManager.service ly@tty2.service dnsmasq.service sshd.service
  libvirtd.service legion-conservation.service iptables.service
  power-profiles-daemon.service systemd-timesyncd.service fstrim.timer)

# ── Output helpers ───────────────────────────────────────────────────────────
if [ -t 1 ]; then C_OK=$'\e[32m'; C_WARN=$'\e[33m'; C_INFO=$'\e[36m'; C_RST=$'\e[0m'
else C_OK=; C_WARN=; C_INFO=; C_RST=; fi
ok()   { printf '  %s✓%s %s\n' "$C_OK"   "$C_RST" "$*"; }
warn() { printf '  %s!%s %s\n' "$C_WARN" "$C_RST" "$*" >&2; }
info() { printf '%s%s%s\n'     "$C_INFO" "$*" "$C_RST"; }

usage() { awk 'NR>1{ if ($0 !~ /^#/) exit; sub(/^# ?/,""); print }' "$0"; exit "${1:-0}"; }

# ── Optional setup steps (registry) ──────────────────────────────────────────
# Each step has a do_<name> function, a `--<name>` flag and a menu line in
# `setup`. New steps are added below via register_step. SELECTED holds the
# currently chosen steps.
STEP_ORDER=()
declare -A STEP_DESC STEP_FN SELECTED
# Steps preselected in `setup` (menu Enter / no TTY = these defaults).
DEFAULT_STEPS=(programs systemd locale)
register_step() { STEP_ORDER+=("$1"); STEP_FN[$1]="$2"; STEP_DESC[$1]="$3"; }
is_selected()   { [ -n "${SELECTED[$1]:-}" ]; }

# Interactive yes/no prompt. Without a TTY (scriptable) always "no".
confirm() {
  local reply
  [ -t 0 ] || return 1
  printf '%s [y/N] ' "$1" >&2
  read -r reply || return 1
  case "$reply" in [yYjJ]*) return 0 ;; *) return 1 ;; esac
}

# ── Argument parsing ─────────────────────────────────────────────────────────
while [ $# -gt 0 ]; do
  case "$1" in
    link|setup|unlink|status|clean) CMD="$1"; EXPLICIT_CMD=1 ;;
    -n|--dry-run)  DRYRUN=1 ;;
    --user-only)   USER_ONLY=1 ;;
    --no-units)    NO_UNITS=1 ;;
    --force)       FORCE=1 ;;
    -c|--config)   shift; CONFIG="${1:?--config needs a file}" ;;
    -h|--help)     usage 0 ;;
    # ── Step flags (see registry) ───────────────────────────────────────────
    --programs)         SELECTED[programs]=1;        FLAG_STEPS_GIVEN=1 ;;
    --remove-programs)  SELECTED[remove-programs]=1; FLAG_STEPS_GIVEN=1 ;;
    --systemd)          SELECTED[systemd]=1;         FLAG_STEPS_GIVEN=1 ;;
    --remove-systemd)   SELECTED[remove-systemd]=1;  FLAG_STEPS_GIVEN=1 ;;
    --groups)           SELECTED[groups]=1;          FLAG_STEPS_GIVEN=1 ;;
    --timezone)         shift; TIMEZONE="${1:?--timezone needs a zone (Region/City)}"
                        SELECTED[timezone]=1;        FLAG_STEPS_GIVEN=1 ;;
    --locale)           SELECTED[locale]=1;          FLAG_STEPS_GIVEN=1 ;;
    --ly-dropin)        SELECTED[ly-dropin]=1;       FLAG_STEPS_GIVEN=1 ;;
    --sudoers)          SELECTED[sudoers]=1;         FLAG_STEPS_GIVEN=1 ;;
    --initramfs)        SELECTED[initramfs]=1;       FLAG_STEPS_GIVEN=1 ;;
    --fonts)            SELECTED[fonts]=1;           FLAG_STEPS_GIVEN=1 ;;
    # Scrub is NOT a generic step flag (must not suppress the setup defaults);
    # it is a separate tri-state so `setup` never scrubs non-interactively
    # unless explicitly asked.
    --scrub)            SCRUB_CHOICE=1 ;;
    --no-scrub)         SCRUB_CHOICE=0 ;;
    *) warn "unknown argument: $1"; usage 1 ;;
  esac
  shift
done

# No explicit subcommand but step flags (or a standalone --scrub) given -> run
# only those steps (scriptable, no linking, no menu).
if [ "$EXPLICIT_CMD" = 0 ] && { [ "$FLAG_STEPS_GIVEN" = 1 ] || [ "$SCRUB_CHOICE" = 1 ]; }; then
  CMD="run-steps"
fi

[ -f "$BASEDIR/$CONFIG" ] || { warn "mapping file not found: $CONFIG"; exit 1; }

# ── Path helpers ─────────────────────────────────────────────────────────────
# `~` -> the user's home.
expand_target() {
  case "$1" in
    "~")    printf '%s\n' "$HOME" ;;
    "~/"*)  printf '%s\n' "$HOME/${1#\~/}" ;;
    *)      printf '%s\n' "$1" ;;
  esac
}
# Target outside $HOME -> needs root.
needs_root() { case "$1" in "$HOME"/*|"$HOME") return 1 ;; *) return 0 ;; esac; }

# `run <root?> cmd…` - run a command (via sudo if needed), honouring dry-run.
run() {
  local root="$1"; shift
  if [ "$DRYRUN" = 1 ]; then
    printf '    [dry] %s%s\n' "$([ "$root" = 1 ] && printf 'sudo ')" "$*"
    return 0
  fi
  if [ "$root" = 1 ]; then sudo "$@"; else "$@"; fi
}

# ── Per-entry actions ────────────────────────────────────────────────────────
link_one() {
  local rel="$1" src="$BASEDIR/$1" target; target="$(expand_target "$2")"
  local root=0; needs_root "$target" && root=1
  { [ "$USER_ONLY" = 1 ] && [ "$root" = 1 ]; } && return 0
  if [ ! -e "$src" ]; then warn "source missing, skipped: $rel"; return 0; fi
  if [ -e "$target" ] && [ ! -L "$target" ]; then
    if [ "$FORCE" = 1 ]; then
      local bak="$target.bak"
      if [ -e "$bak" ]; then bak="$target.bak.$(date +%s)"; fi
      run "$root" mv "$target" "$bak"; ok "backed up: $target -> $bak"
    else
      warn "real file/directory, skipped (use --force to back up & replace): $target"
      SKIPPED_REAL=$((SKIPPED_REAL + 1)); return 0
    fi
  fi
  local parent; parent="$(dirname "$target")"
  # A dead (broken) symlink as the parent path - e.g. left over from an old
  # setup - would otherwise make `mkdir -p` fail with "File exists" and abort the
  # whole run under `set -e`. A dead symlink has no content -> safe to remove
  # (only real, dangling symlinks; real files/dirs are left untouched).
  if [ -L "$parent" ] && [ ! -e "$parent" ]; then run "$root" rm -f "$parent"; fi
  if [ ! -d "$parent" ]; then
    run "$root" mkdir -p "$parent" \
      || { warn "parent path not creatable, skipped: $parent"; return 0; }
  fi
  run "$root" ln -sfn "$src" "$target"
  ok "$2 -> $rel"
}

unlink_one() {
  local rel="$1" src="$BASEDIR/$1" target; target="$(expand_target "$2")"
  local root=0; needs_root "$target" && root=1
  { [ "$USER_ONLY" = 1 ] && [ "$root" = 1 ]; } && return 0
  if [ -L "$target" ]; then
    if [ "$(readlink "$target")" = "$src" ]; then
      run "$root" rm "$target"; ok "removed: $2"
    else
      warn "symlink points elsewhere (kept): $target"
    fi
  elif [ -e "$target" ]; then
    warn "not a symlink (kept): $target"
  fi
}

status_one() {
  local rel="$1" src="$BASEDIR/$1" target; target="$(expand_target "$2")"
  local state
  if [ -L "$target" ]; then
    if [ "$(readlink "$target")" = "$src" ]; then state="${C_OK}ok${C_RST}"
    else state="${C_WARN}link->$(readlink "$target")${C_RST}"; fi
  elif [ -e "$target" ]; then state="${C_WARN}real file${C_RST}"
  else state="missing"; fi
  printf '  %-46s %s\n' "$2" "$state"
}

clean_one() {
  local target; target="$(expand_target "$2")"
  local root=0; needs_root "$target" && root=1
  { [ "$USER_ONLY" = 1 ] && [ "$root" = 1 ]; } && return 0
  local b
  shopt -s nullglob
  for b in "$target.bak" "$target".bak.[0-9]*; do
    { [ -e "$b" ] || [ -L "$b" ]; } || continue
    run "$root" rm -rf "$b"; ok "deleted: $b"
  done
  shopt -u nullglob
}

# ── Optional step functions ──────────────────────────────────────────────────
# Install packages from setup/programs.txt. Delegates to setup/install-programs
# (bootstraps yay from the AUR if needed; skips already-installed packages). Runs
# BEFORE linking so the units reactivated afterwards exist.
do_programs_install() {
  local script="$BASEDIR/setup/install-programs"
  [ -x "$script" ] || { warn "setup/install-programs missing/not executable: $script"; return 0; }
  info "Installing packages from setup/programs.txt (yay)"
  if [ "$DRYRUN" = 1 ]; then printf '    [dry] %s\n' "$script"; return 0; fi
  "$script" || warn "package installation not (fully) successful"
}
register_step programs do_programs_install "Install packages from programs.txt"

# Remove explicitly installed packages that are NOT in the manifest
# (programs.txt) - pulls the system onto the tracked package list. Deliberately
# asks first and defaults to "no" (aggressive operation); pacman -Rns also
# removes dependencies and config leftovers.
do_programs_remove() {
  command -v pacman >/dev/null 2>&1 || { warn "pacman missing - package removal skipped"; return 0; }
  local manifest="$BASEDIR/setup/programs.txt"
  [ -f "$manifest" ] || { warn "programs.txt missing - nothing to remove"; return 0; }
  info "Finding untracked packages (explicitly installed but not in programs.txt)"
  local extras
  extras="$(comm -23 <(pacman -Qqe | sort -u) <(awk 'NF{print $1}' "$manifest" | sort -u))"
  if [ -z "$extras" ]; then ok "no untracked packages - nothing to remove"; return 0; fi
  printf '  To remove:\n'; printf '    %s\n' $extras
  if [ "$DRYRUN" = 1 ]; then printf '    [dry] sudo pacman -Rns %s\n' "$extras"; return 0; fi
  if confirm "  Really remove these packages (pacman -Rns)?"; then
    # shellcheck disable=SC2086
    run 1 pacman -Rns $extras || warn "package removal not (fully) successful"
  else
    info "package removal skipped"
  fi
}
register_step remove-programs do_programs_remove "Remove untracked packages (prune)"

# Closing hint after linking: report skipped real targets prominently and remind
# the user to apply the freshly linked shell config. (A script cannot reload the
# interactive parent shell itself - hence the explicit hint instead of a useless
# `source` inside the script.)
next_steps() {
  if [ "$SKIPPED_REAL" -gt 0 ]; then
    warn "$SKIPPED_REAL real target(s) skipped - use './install --force' to back up to .bak and replace."
  fi
  [ "$DRYRUN" = 1 ] && return 0
  info "Next steps"
  printf '  • %ssource ~/.bashrc%s  - apply the shell config now (also loads ~/.nix-profile via nix.sh)\n' "$C_OK" "$C_RST"
  printf '  • log in again once for the .bash_profile env (GTK_THEME, QT_QPA_PLATFORMTHEME, XDG_*)\n'
  # After the fresh-machine setup, several changes (system units, initramfs,
  # groups, timezone, locale) only take full effect after a reboot.
  if [ "$CMD" = setup ]; then
    printf '  • %sreboot your PC%s to fully apply system units, initramfs, groups, timezone and locale\n' "$C_WARN" "$C_RST"
  fi
}

# Generate the freshly linked locales (/etc/locale.gen), idempotent.
do_locale() {
  if [ "$USER_ONLY" = 1 ]; then warn "--user-only: locale-gen skipped"; return 0; fi
  info "Generating locales (locale-gen)"
  run 1 locale-gen || warn "locale-gen failed"
}
register_step locale do_locale "Generate locales (locale-gen)"

# Interactive menu: pick optional steps. With steps preselected via flags
# (FLAG_STEPS_GIVEN) it takes them as-is; without a TTY the DEFAULT_STEPS apply.
choose_steps() {
  [ "$FLAG_STEPS_GIVEN" = 1 ] && return 0
  if [ ! -t 0 ]; then for s in "${DEFAULT_STEPS[@]}"; do SELECTED[$s]=1; done; return 0; fi
  info "Select optional steps (numbers separated by spaces; Enter = defaults)"
  local i=1 idx=() def
  for s in "${STEP_ORDER[@]}"; do
    def=""; for d in "${DEFAULT_STEPS[@]}"; do [ "$d" = "$s" ] && def=" (default)"; done
    printf '  [%d] %s%s\n' "$i" "${STEP_DESC[$s]}" "$def"; idx[$i]="$s"; i=$((i+1))
  done
  printf '> '; local line n; read -r line || line=""
  if [ -z "$line" ]; then for s in "${DEFAULT_STEPS[@]}"; do SELECTED[$s]=1; done; return 0; fi
  for n in $line; do [ -n "${idx[$n]:-}" ] && SELECTED[${idx[$n]}]=1; done
}

# Linking core (symlinks only). Package/unit steps run separately.
do_symlinks() {
  info "Creating symlinks (${#SRCS[@]} entries)"
  for i in "${!SRCS[@]}"; do link_one "${SRCS[$i]}" "${TGTS[$i]}"; done
}

reactivate_units() {
  [ "$NO_UNITS" = 1 ] && return 0
  # Deliberately `enable`, not `reenable`: our unit files are symlinks (linked
  # units); `reenable` would delete exactly that unit symlink during its internal
  # `disable`. `enable` is idempotent and only creates the missing enablement
  # link (…​.wants/) - it also survives a repo move because the unit symlink sits
  # at the standard path.
  info "Activating systemd user units"
  run 0 systemctl --user daemon-reload || warn "daemon-reload failed"
  for u in "${USER_UNITS[@]}"; do
    if [ "$DRYRUN" = 1 ]; then run 0 systemctl --user enable "$u"
    else run 0 systemctl --user enable "$u" >/dev/null 2>&1 || warn "user unit not activated: $u"; fi
  done
  [ "$USER_ONLY" = 1 ] && return 0
  info "Activating systemd system units (sudo)"
  for u in "${SYSTEM_UNITS[@]}"; do
    if [ "$DRYRUN" = 1 ]; then run 1 systemctl enable "$u"
    else run 1 systemctl enable "$u" >/dev/null 2>&1 || warn "system unit not activated: $u"; fi
  done
}
register_step systemd reactivate_units "Activate systemd units (enable)"

# Counterpart to reactivate_units: deactivate those same units. Note: our unit
# files are linked units (symlinks at the standard path) - for such units
# `disable` also removes that symlink, so the unit is gone entirely afterwards
# (re-linking via `./install` recreates it). Hence the confirmation.
do_systemd_disable() {
  [ "$DRYRUN" = 0 ] && ! confirm "  Really deactivate the systemd units?" && { info "skipped"; return 0; }
  info "Deactivating systemd user units"
  for u in "${USER_UNITS[@]}"; do
    run 0 systemctl --user disable "$u" >/dev/null 2>&1 || warn "user unit not deactivated: $u"
  done
  [ "$USER_ONLY" = 1 ] && return 0
  info "Deactivating systemd system units (sudo)"
  for u in "${SYSTEM_UNITS[@]}"; do
    run 1 systemctl disable "$u" >/dev/null 2>&1 || warn "system unit not deactivated: $u"
  done
}
register_step remove-systemd do_systemd_disable "Deactivate systemd units (disable)"

# Add the user to the groups the tracked tools need. `GROUPS` is reserved in Bash
# (current GIDs) - hence GROUP_LIST. docker/wireshark deliberately excluded (only
# needed if you also install those packages).
GROUP_LIST="wheel,input,kvm,libvirt,uucp,disk,lock"
do_groups() {
  local user="${SUDO_USER:-${USER:-}}"
  [ -n "$user" ] || { warn "no user determinable - groups skipped"; return 0; }
  info "Adding user '$user' to groups: $GROUP_LIST"
  run 1 usermod -aG "$GROUP_LIST" "$user" || warn "usermod failed"
  info "(group change takes effect after re-login)"
}
register_step groups do_groups "Add user to groups ($GROUP_LIST)"

# Set the timezone via the symlink /etc/localtime -> /usr/share/zoneinfo/<zone>.
# Zone from --timezone or (in the menu) asked interactively.
do_timezone() {
  local tz="$TIMEZONE"
  if [ -z "$tz" ] && [ -t 0 ]; then
    printf '  Timezone (Region/City, e.g. Europe/Vienna): ' >&2; read -r tz || tz=""
  fi
  [ -n "$tz" ] || { warn "no timezone given - skipped"; return 0; }
  if [ ! -e "/usr/share/zoneinfo/$tz" ]; then warn "unknown timezone: $tz - skipped"; return 0; fi
  info "Setting timezone: $tz"
  run 1 ln -sf "/usr/share/zoneinfo/$tz" /etc/localtime || warn "setting timezone failed"
}
register_step timezone do_timezone "Set timezone (/etc/localtime)"

# Deploy the ly@tty2 drop-ins as REAL copies onto the root partition (not
# symlinked via links.conf): systemd reads unit drop-ins early at manager start,
# when a /home symlink would still be a dead link. Then daemon-reload.
LY_DROPIN_DIR="/etc/systemd/system/ly@tty2.service.d"
do_ly_dropin() {
  local src="$BASEDIR/config/systemd-system/ly@tty2.service.d"
  [ -d "$src" ] || { warn "ly@tty2 drop-in source missing: $src"; return 0; }
  info "Copying ly@tty2 drop-ins to $LY_DROPIN_DIR"
  run 1 install -d -m755 "$LY_DROPIN_DIR" || { warn "directory not creatable"; return 0; }
  run 1 install -m644 "$src"/wait-home.conf "$src"/keymap.conf "$LY_DROPIN_DIR"/ \
    || warn "drop-in copy failed"
  run 1 systemctl daemon-reload || warn "daemon-reload failed"
}
register_step ly-dropin do_ly_dropin "Deploy ly@tty2 drop-ins (real copies)"

# Passwordless sudo for the wheel group - a deliberate convenience choice of this
# setup. As a drop-in in /etc/sudoers.d/ (0440), first checked with `visudo -c`
# on a temp file so broken sudoers syntax cannot lock you out of the system.
do_sudoers() {
  local file="/etc/sudoers.d/10-wheel-nopasswd"
  local rule="%wheel ALL=(ALL:ALL) NOPASSWD: ALL"
  info "Setting up passwordless sudo for wheel: $file"
  if [ "$DRYRUN" = 1 ]; then
    printf "    [dry] printf '%s' | visudo -c && sudo install -m0440 -> %s\n" "$rule" "$file"; return 0
  fi
  local tmp; tmp="$(mktemp)"; printf '%s\n' "$rule" > "$tmp"
  if ! visudo -cf "$tmp" >/dev/null 2>&1; then
    warn "sudoers syntax invalid - skipped"; rm -f "$tmp"; return 0
  fi
  run 1 install -m0440 -o root -g root "$tmp" "$file" || warn "sudoers file not installed"
  rm -f "$tmp"
}
register_step sudoers do_sudoers "Passwordless sudo for wheel (sudoers.d)"

# Rebuild the initramfs (mkinitcpio -P) - needed after changes to
# /etc/mkinitcpio.conf (linked via links.conf).
do_initramfs() {
  command -v mkinitcpio >/dev/null 2>&1 || { warn "mkinitcpio missing - skipped"; return 0; }
  info "Regenerating initramfs (mkinitcpio -P)"
  run 1 mkinitcpio -P || warn "mkinitcpio failed"
}
register_step initramfs do_initramfs "Regenerate initramfs (mkinitcpio -P)"

# Install the font packages (also part of programs.txt, but installable on their
# own here) and rebuild the fontconfig cache so freshly installed fonts are
# picked up without a re-login.
FONT_PACKAGES=(noto-fonts noto-fonts-cjk noto-fonts-emoji ttf-jetbrains-mono-nerd)
do_fonts() {
  info "Installing fonts and refreshing the font cache: ${FONT_PACKAGES[*]}"
  if [ "$DRYRUN" = 1 ]; then
    printf '    [dry] yay -S --needed --noconfirm %s\n' "${FONT_PACKAGES[*]}"
    printf '    [dry] fc-cache -f\n'; return 0
  fi
  if command -v yay >/dev/null 2>&1; then
    yay -S --needed --noconfirm "${FONT_PACKAGES[@]}" || warn "font install not (fully) successful"
  elif command -v pacman >/dev/null 2>&1; then
    sudo pacman -S --needed --noconfirm "${FONT_PACKAGES[@]}" || warn "font install not (fully) successful"
  else
    warn "no package manager - font install skipped"
  fi
  if command -v fc-cache >/dev/null 2>&1; then fc-cache -f || warn "fc-cache failed"
  else warn "fc-cache missing - font cache not refreshed"; fi
}
register_step fonts do_fonts "Install fonts + refresh font cache (fc-cache)"

# Non-owner scrub: replace personal data in the WORKING COPY with generic
# placeholders BEFORE it is linked, so a foreign user never deploys the owner's
# git identity/signing key, backup host or GPU pin. Idempotent. Driven by the
# owner question in `setup` (or forced via `--scrub`) - NOT a menu step.
do_scrub() {
  info "Scrubbing personal data from the working copy (non-owner)"
  local gc="$BASEDIR/config/git/.gitconfig"
  local rb="$BASEDIR/config/usrbin/restic-backup"
  local env="$BASEDIR/config/hypr/env.lua"
  if [ "$DRYRUN" = 1 ]; then
    [ -f "$gc" ]  && printf '    [dry] reset git identity/signing in config/git/.gitconfig\n'
    [ -f "$rb" ]  && printf '    [dry] replace restic backup host in config/usrbin/restic-backup\n'
    [ -f "$env" ] && grep -q 'WLR_DRM_DEVICES' "$env" \
      && printf '    [dry] drop the WLR_DRM_DEVICES GPU pin in config/hypr/env.lua\n'
    return 0
  fi
  # git: drop the owner's name/email/signing key, keep the functional editor
  # setting. Signing is removed on purpose - a bogus signingkey would make every
  # commit fail for a foreign user.
  if [ -f "$gc" ]; then
    cat > "$gc" <<'EOF'
[user]
	email =
	name =
[core]
	editor = nvim
EOF
    ok "reset git identity/signing: config/git/.gitconfig"
  else
    warn "config/git/.gitconfig missing - git scrub skipped"
  fi
  # restic: replace whatever backup host is set as the default with a showcase
  # placeholder (matches everything between `RESTIC_REPOSITORY:-` and `}`).
  if [ -f "$rb" ]; then
    if sed -i 's#\(RESTIC_REPOSITORY:-\)[^}]*#\1sftp:user@ip:drive/path/to/your/backup#' "$rb"; then
      ok "restic backup host -> showcase placeholder: config/usrbin/restic-backup"
    else
      warn "restic scrub failed"
    fi
  else
    warn "config/usrbin/restic-backup missing - restic scrub skipped"
  fi
  # GPU: the owner pins the integrated GPU via WLR_DRM_DEVICES (hides the discrete
  # card). For anyone else that exact PCI path is wrong - drop the line so wlroots
  # auto-detects their GPU (maximum compatibility). No-op if already absent.
  if [ -f "$env" ]; then
    if grep -q 'WLR_DRM_DEVICES' "$env"; then
      sed -i '/hl\.env("WLR_DRM_DEVICES"/d' "$env" \
        && ok "removed the GPU pin (WLR_DRM_DEVICES): config/hypr/env.lua" \
        || warn "GPU scrub failed"
    fi
  else
    warn "config/hypr/env.lua missing - GPU scrub skipped"
  fi
}

# ── links.conf pipeline: parse -> validate -> build (globs) -> execute ────────
# Explicit phases so execution never sees a malformed entry: the raw entries
# (verbatim from the file, no globbing) are validated first; only then is the
# work table (SRCS/TGTS) built by expanding globs. Read fully first - otherwise a
# sudo password prompt collides with the read loop's stdin.
RAW_SRC=(); RAW_TGT=(); RAW_OPT=(); RAW_LN=()

# Phase 1 - parse: read the file into raw arrays (source, target, 3rd field, line
# number). No filesystem access and no globbing here.
parse_links() {
  local ln=0 line s t extra
  while IFS= read -r line || [ -n "$line" ]; do
    ln=$((ln + 1))
    line="${line%%#*}"                 # strip the comment from # onwards
    read -r s t extra <<<"$line" || true
    [ -z "${s:-}" ] && continue        # blank or comment-only line
    RAW_SRC+=("$s"); RAW_TGT+=("${t:-}"); RAW_OPT+=("${extra:-}"); RAW_LN+=("$ln")
  done < "$BASEDIR/$CONFIG"
}

# Report a validation problem at a specific links.conf line.
verr() { printf '  %s✗%s %s:%s: %s\n' "$C_WARN" "$C_RST" "$CONFIG" "$1" "$2" >&2; }

# Target prefix allowlist: a target must live under one of these (add a prefix
# here to opt one in). Keeps a stray `/tmp/...`, `/usr/...` or `/` target - which
# would write outside the intended user/system config areas - out of the config.
ALLOWED_TARGET_PREFIXES=("$HOME" "/etc" "/usr/local")

# Phase 2 - validate: check the raw entries and collect ALL problems (no
# filesystem mutation). Returns non-zero if anything is wrong. Every command runs
# this before touching the filesystem, so a broken config aborts the whole run
# instead of silently skipping lines.
validate_links() {
  local i s t opt ln tgt m et ok p errs=0
  local -A seen_src seen_tgt
  if [ "${#RAW_SRC[@]}" -eq 0 ]; then warn "$CONFIG: no entries"; return 1; fi
  for i in "${!RAW_SRC[@]}"; do
    s="${RAW_SRC[$i]}"; t="${RAW_TGT[$i]}"; opt="${RAW_OPT[$i]}"; ln="${RAW_LN[$i]}"
    # A well-formed line is exactly `<source> <target>`.
    if [ -z "$t" ]; then verr "$ln" "missing target for source '$s'"; errs=1; continue; fi
    if [ -n "$opt" ]; then
      verr "$ln" "unexpected extra field(s) '$opt' (expected: <source> <target>)"; errs=1
    fi
    # Duplicate source (same line effectively repeated).
    if [ -n "${seen_src[$s]:-}" ]; then
      verr "$ln" "duplicate source '$s' (first seen at line ${seen_src[$s]})"; errs=1
    else seen_src[$s]="$ln"; fi
    tgt="$(expand_target "$t")"
    # Target must sit under an allowed prefix (~ / /etc / /usr/local).
    ok=0
    for p in "${ALLOWED_TARGET_PREFIXES[@]}"; do
      case "$tgt/" in "$p"/*) ok=1; break ;; esac
    done
    if [ "$ok" != 1 ]; then
      verr "$ln" "target prefix not allowed: '$t' (allowed: ~ /etc /usr/local)"; errs=1
    fi
    # Duplicate target: compare the FINAL (expanded) targets so two entries never
    # fight over the same path. Globs are expanded per match here.
    if [[ "$s" == *"*"* ]]; then
      shopt -s nullglob
      for m in "$BASEDIR"/$s; do
        et="${tgt%/}/${m##*/}"
        if [ -n "${seen_tgt[$et]:-}" ]; then
          verr "$ln" "duplicate target '$et' (first seen at line ${seen_tgt[$et]})"; errs=1
        else seen_tgt[$et]="$ln"; fi
      done
      shopt -u nullglob
    else
      if [ -n "${seen_tgt[$tgt]:-}" ]; then
        verr "$ln" "duplicate target '$tgt' (first seen at line ${seen_tgt[$tgt]})"; errs=1
      else seen_tgt[$tgt]="$ln"; fi
    fi
  done
  return "$errs"
}

# Phase 3 - build: expand globs into the work table SRCS/TGTS. A glob source
# (e.g. `config/usrbin/*`) links every match individually into <target>/<name>,
# so the target directory stays real and foreign entries in it are preserved.
build_table() {
  SRCS=(); TGTS=()
  local i s t m
  for i in "${!RAW_SRC[@]}"; do
    s="${RAW_SRC[$i]}"; t="${RAW_TGT[$i]}"
    if [[ "$s" == *"*"* ]]; then
      shopt -s nullglob
      for m in "$BASEDIR"/$s; do SRCS+=("${m#"$BASEDIR"/}"); TGTS+=("${t%/}/${m##*/}"); done
      shopt -u nullglob
    else
      SRCS+=("$s"); TGTS+=("$t")
    fi
  done
}

SRCS=(); TGTS=()
parse_links
if ! validate_links; then
  warn "$CONFIG is invalid - aborting (nothing changed)."
  exit 1
fi
build_table
[ "${#SRCS[@]}" -gt 0 ] || { warn "no entries in $CONFIG"; exit 1; }

# ── Execution ────────────────────────────────────────────────────────────────
[ "$DRYRUN" = 1 ] && info "- Dry run: nothing is changed -"
case "$CMD" in
  link)
    do_symlinks
    reactivate_units
    next_steps
    ;;
  setup)
    # One-command bootstrap for a fresh machine.
    FORCE=1
    info "Setup: optional steps -> link (--force) -> units"
    choose_steps
    # Owner check: only the repository owner should deploy the personal identity
    # data. --scrub/--no-scrub win; otherwise ask on a TTY ("no" -> scrub before
    # linking). Non-interactively WITHOUT an explicit flag we keep the working
    # copy intact - never scrub silently in a script/CI.
    SCRUB=0
    if [ "$SCRUB_CHOICE" = 1 ]; then SCRUB=1
    elif [ "$SCRUB_CHOICE" = 0 ]; then SCRUB=0
    elif [ -t 0 ]; then confirm "  Are you the repository owner?" || SCRUB=1
    else warn "non-interactive setup: personal data kept as-is (use --scrub to strip it, --no-scrub to silence)"
    fi
    is_selected programs && do_programs_install
    [ "$SCRUB" = 1 ] && do_scrub
    do_symlinks
    is_selected systemd && reactivate_units
    is_selected remove-systemd && do_systemd_disable
    is_selected groups && do_groups
    is_selected timezone && do_timezone
    is_selected ly-dropin && do_ly_dropin
    is_selected sudoers && do_sudoers
    is_selected initramfs && do_initramfs
    is_selected fonts && do_fonts
    is_selected locale && do_locale
    is_selected remove-programs && do_programs_remove
    next_steps
    ;;
  run-steps)
    # Only the optional steps chosen via flags (scriptable), in canonical order
    # (STEP_ORDER). Scrub is not a step - run it explicitly on --scrub.
    for s in "${STEP_ORDER[@]}"; do
      is_selected "$s" && "${STEP_FN[$s]}"
    done
    [ "$SCRUB_CHOICE" = 1 ] && do_scrub
    ;;
  unlink)
    info "Removing symlinks"
    for i in "${!SRCS[@]}"; do unlink_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    warn "Note: systemd units are not deactivated - do it manually if needed via 'systemctl [--user] disable …'."
    ;;
  status)
    info "Status (${#SRCS[@]} entries)"
    for i in "${!SRCS[@]}"; do status_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    ;;
  clean)
    info "Deleting .bak backups of the managed targets"
    for i in "${!SRCS[@]}"; do clean_one "${SRCS[$i]}" "${TGTS[$i]}"; done
    ;;
esac
